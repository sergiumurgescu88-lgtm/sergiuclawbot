<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — AgentulMeu</title>
<meta name="description" content="Panoul tău de control. Generează fișiere MD, monitorizează agenții și descarcă configurările.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased;line-height:1.6;overflow-x:hidden}

/* ═══ ANIMATIONS ═══ */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes floatSlow{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scaleIn{from{opacity:0;transform:scale(0.96)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes progressPulse{0%,100%{opacity:1}50%{opacity:.7}}

.float{animation:float 6s ease-in-out infinite}
.float-slow{animation:floatSlow 8s ease-in-out infinite}
.float-delay{animation:float 6s ease-in-out 2s infinite}
.fade-in{animation:fadeInUp .6s ease-out both}
.fade-in-1{animation:fadeInUp .6s ease-out .1s both}
.fade-in-2{animation:fadeInUp .6s ease-out .2s both}
.fade-in-3{animation:fadeInUp .6s ease-out .3s both}
.scale-in{animation:scaleIn .4s ease-out both}

/* ═══ NAV ═══ */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.88);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);transition:all .3s ease}
nav.scrolled{box-shadow:var(--shadow-md)}
.nav-inner{max-width:1280px;margin:0 auto;padding:0 32px;height:68px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-icon{width:38px;height:38px;border-radius:11px;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.05rem;color:#fff;box-shadow:0 4px 14px rgba(249,115,22,0.3)}
.nav-logo-text{font-size:1.05rem;font-weight:700;color:var(--text)}
.nav-logo-text span{color:var(--accent)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{color:var(--text-2);text-decoration:none;font-size:0.88rem;font-weight:500;transition:color .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--accent);transition:width .3s ease;border-radius:1px}
.nav-links a:hover{color:var(--text)}
.nav-links a:hover::after{width:100%}
.nav-user{display:flex;align-items:center;gap:12px}
.nav-avatar{width:36px;height:36px;border-radius:10px;background:var(--bg-3);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:var(--text-2);border:1px solid var(--border)}
.nav-logout{padding:7px 16px;border-radius:9px;font-size:0.82rem;font-weight:600;color:var(--text-2);text-decoration:none;border:1px solid var(--border);background:transparent;cursor:pointer;transition:all .2s;font-family:Inter,sans-serif}
.nav-logout:hover{border-color:var(--red);color:var(--red);background:rgba(220,38,38,0.04)}

/* ═══ MAIN ═══ */
main{flex:1;padding:100px 32px 80px;max-width:1280px;margin:0 auto;width:100%}

/* ═══ WELCOME SECTION ═══ */
.welcome-section{margin-bottom:48px;animation:fadeInUp .6s ease-out both}
.welcome-section h1{font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:800;letter-spacing:-0.03em;margin-bottom:8px}
.welcome-section h1 .wave{display:inline-block;animation:float 3s ease-in-out infinite}
.welcome-section p{color:var(--text-2);font-size:1rem;max-width:600px}
.welcome-actions{display:flex;gap:12px;margin-top:20px;flex-wrap:wrap}

/* ═══ BUTTONS ═══ */
.btn{padding:12px 24px;border-radius:12px;font-size:0.88rem;font-weight:600;cursor:pointer;transition:all .3s cubic-bezier(0.25,0.46,0.45,0.94);font-family:Inter,sans-serif;border:none;display:inline-flex;align-items:center;gap:8px;text-decoration:none}
.btn-primary{background:var(--accent);color:#fff;box-shadow:0 4px 14px rgba(249,115,22,0.25)}
.btn-primary:hover{background:var(--accent-2);transform:translateY(-2px);box-shadow:0 6px 24px rgba(249,115,22,0.35)}
.btn-secondary{background:var(--bg);color:var(--text);border:1.5px solid var(--border-2);box-shadow:var(--shadow-sm)}
.btn-secondary:hover{border-color:var(--text);transform:translateY(-2px);box-shadow:var(--shadow-md)}
.btn-green{background:var(--green);color:#fff;box-shadow:0 4px 14px rgba(22,163,74,0.25)}
.btn-green:hover{background:#15803d;transform:translateY(-2px);box-shadow:0 6px 24px rgba(22,163,74,0.35)}
.btn-blue{background:var(--blue);color:#fff;box-shadow:0 4px 14px rgba(37,99,235,0.25)}
.btn-blue:hover{background:#1d4ed8;transform:translateY(-2px);box-shadow:0 6px 24px rgba(37,99,235,0.35)}
.btn-ghost{background:transparent;color:var(--text-2);border:1.5px solid var(--border)}
.btn-ghost:hover{border-color:var(--text);color:var(--text);transform:translateY(-1px)}
.btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}
.btn-sm{padding:8px 16px;font-size:0.8rem;border-radius:10px}
.btn-lg{padding:16px 32px;font-size:0.95rem;border-radius:14px}

/* ═══ FRAMEWORK SELECTOR ═══ */
.framework-section{margin-bottom:56px}
.framework-section h2{font-size:1.15rem;font-weight:700;margin-bottom:6px;letter-spacing:-0.02em}
.framework-section .subtitle{color:var(--text-2);font-size:0.9rem;margin-bottom:24px}
.framework-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.framework-card{background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-xl);padding:32px;position:relative;overflow:hidden;transition:all .4s cubic-bezier(0.25,0.46,0.45,0.94)}
.framework-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;opacity:0;transition:opacity .3s ease}
.framework-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-xl)}
.framework-card:hover::before{opacity:1}
.framework-card.blue::before{background:linear-gradient(90deg,#2563eb,#3b82f6)}
.framework-card.orange::before{background:linear-gradient(90deg,var(--accent),var(--accent-2))}
.framework-card.recommended{border-color:var(--accent);box-shadow:var(--shadow-float)}
.framework-card.recommended::before{opacity:1}
.framework-badge{position:absolute;top:16px;right:16px;background:var(--accent);color:#fff;padding:4px 12px;border-radius:999px;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em}
.framework-header{display:flex;align-items:center;gap:14px;margin-bottom:20px}
.framework-icon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0}
.framework-icon.blue-icon{background:var(--blue-glow)}
.framework-icon.orange-icon{background:var(--accent-glow)}
.framework-name{font-size:1.1rem;font-weight:700;margin-bottom:2px}
.framework-desc{font-size:0.8rem;color:var(--text-3)}
.framework-features{list-style:none;margin-bottom:24px}
.framework-features li{padding:8px 0;font-size:0.85rem;color:var(--text-2);display:flex;align-items:flex-start;gap:8px;border-bottom:1px solid var(--border)}
.framework-features li:last-child{border:none}
.framework-features .check{color:var(--green);font-weight:700;flex-shrink:0;margin-top:1px}
.framework-features code{background:var(--bg-2);padding:2px 7px;border-radius:5px;font-size:0.78rem;font-family:'JetBrains Mono',monospace;color:var(--green)}

/* ═══ SECTION HEADERS ═══ */
.section-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:24px}
.section-header h2{font-size:1.15rem;font-weight:700;letter-spacing:-0.02em}
.section-header .section-actions{display:flex;gap:10px;flex-wrap:wrap}

/* ═══ GENERATION PROGRESS ═══ */
.progress-section{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 24px;margin-bottom:32px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.progress-info{flex:1;min-width:200px}
.progress-info .label{font-size:0.82rem;font-weight:600;color:var(--text-2);margin-bottom:6px}
.progress-bar-outer{height:8px;background:var(--bg-3);border-radius:4px;overflow:hidden}
.progress-bar-inner{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent-2));border-radius:4px;transition:width .5s cubic-bezier(0.25,0.46,0.45,0.94);min-width:0}
.progress-bar-inner.generating{animation:progressPulse 1.5s ease-in-out infinite}
.progress-count{font-size:1.4rem;font-weight:800;color:var(--accent);white-space:nowrap}
.progress-status{font-size:0.78rem;color:var(--text-3);margin-top:2px}

/* ═══ FILES GRID ═══ */
.files-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:56px}
.file-card{background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:28px 24px;position:relative;overflow:hidden;transition:all .4s cubic-bezier(0.25,0.46,0.45,0.94)}
.file-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent-2));opacity:0;transition:opacity .3s ease}
.file-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-xl);border-color:rgba(249,115,22,0.15)}
.file-card:hover::before{opacity:1}
.file-card.done{border-color:rgba(22,163,74,0.2)}
.file-card.done::before{background:linear-gradient(90deg,var(--green),#15803d)}
.file-card.done:hover{border-color:rgba(22,163,74,0.3)}
.file-card.generating{border-color:rgba(249,115,22,0.3)}
.file-card.generating::before{opacity:1;animation:progressPulse 1.5s ease-in-out infinite}

.file-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:16px}
.file-icon.orange{background:var(--accent-glow)}
.file-icon.green{background:var(--green-glow)}
.file-icon.blue{background:var(--blue-glow)}
.file-icon.purple{background:var(--purple-glow)}

.file-name{font-size:0.95rem;font-weight:700;margin-bottom:4px;color:var(--text)}
.file-desc{font-size:0.8rem;color:var(--text-3);margin-bottom:16px;line-height:1.5;min-height:36px}

.file-status{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:999px;font-size:0.72rem;font-weight:600;margin-bottom:16px}
.file-status.pending{background:var(--bg-3);color:var(--text-3)}
.file-status.generating{background:var(--accent-glow);color:var(--accent)}
.file-status.generating .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse 1s ease-in-out infinite}
.file-status.done{background:var(--green-glow);color:var(--green)}

.file-actions{display:flex;gap:8px}
.file-actions .btn{flex:1;justify-content:center;padding:8px 12px;font-size:0.78rem;border-radius:10px}

/* ═══ STATS ROW ═══ */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px}
.stat-card{background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:24px;text-align:center;transition:all .4s cubic-bezier(0.25,0.46,0.45,0.94)}
.stat-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg)}
.stat-card .stat-icon{font-size:1.3rem;margin-bottom:8px}
.stat-card .stat-value{font-size:1.8rem;font-weight:800;letter-spacing:-0.03em;margin-bottom:4px}
.stat-card .stat-value.orange{color:var(--accent)}
.stat-card .stat-value.green{color:var(--green)}
.stat-card .stat-value.blue{color:var(--blue)}
.stat-card .stat-label{font-size:0.78rem;color:var(--text-3);font-weight:500}

/* ═══ REPORTS SECTION ═══ */
.reports-section{background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-xl);padding:36px;margin-bottom:56px;transition:all .4s ease}
.reports-section:hover{box-shadow:var(--shadow-lg)}
.reports-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:28px}
.reports-header h2{font-size:1.15rem;font-weight:700;letter-spacing:-0.02em}
.reports-header .subtitle{color:var(--text-2);font-size:0.88rem;margin-top:4px}
.reports-actions{display:flex;gap:10px;flex-wrap:wrap}

.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:24px}
.chart-card{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);padding:24px;transition:all .3s ease}
.chart-card:hover{border-color:var(--border-2)}
.chart-card h3{font-size:0.9rem;font-weight:700;margin-bottom:16px}

.chart-bar{margin-bottom:12px}
.chart-bar-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}
.chart-bar-label{font-size:0.8rem;font-weight:600;color:var(--text)}
.chart-bar-value{font-size:0.78rem;color:var(--text-3)}
.chart-bar-track{height:8px;background:var(--bg-3);border-radius:4px;overflow:hidden}
.chart-bar-fill{height:100%;border-radius:4px;transition:width .6s cubic-bezier(0.25,0.46,0.45,0.94)}

.daily-chart{display:flex;align-items:flex-end;gap:8px;height:100px;padding-top:10px}
.daily-bar{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.daily-bar-value{font-size:0.7rem;color:var(--text-3);font-weight:600}
.daily-bar-track{width:100%;background:var(--bg-3);border-radius:4px 4px 0 0;min-height:4px;transition:height .5s ease}
.daily-bar-label{font-size:0.65rem;color:var(--text-3)}

.top-questions{margin-top:0}
.top-question{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
.top-question:last-child{border:none}
.top-question .rank{width:28px;height:28px;border-radius:8px;background:var(--accent-glow);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:800;color:var(--accent);flex-shrink:0}
.top-question .text{flex:1;font-size:0.85rem;color:var(--text)}
.top-question .count{font-size:0.72rem;color:var(--text-3);font-weight:600;background:var(--bg-2);padding:3px 10px;border-radius:8px}

/* ═══ HOW SECTION ═══ */
.how-section{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-xl);padding:36px;margin-bottom:56px}
.how-section h2{font-size:1.1rem;font-weight:700;margin-bottom:24px}
.how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.how-step{text-align:center}
.how-step .step-num{width:36px;height:36px;border-radius:10px;background:var(--accent);color:#fff;display:inline-flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;margin-bottom:10px;box-shadow:0 4px 12px rgba(249,115,22,0.3)}
.how-step h3{font-size:0.9rem;font-weight:700;margin-bottom:4px}
.how-step p{font-size:0.8rem;color:var(--text-3);line-height:1.5}

/* ═══ MODAL ═══ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.35);backdrop-filter:blur(12px);z-index:200;display:none;align-items:center;justify-content:center;padding:24px}
.modal-overlay.active{display:flex}
.modal{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-xl);width:100%;max-width:680px;max-height:80vh;display:flex;flex-direction:column;box-shadow:var(--shadow-xl);animation:fadeInUp .3s ease-out}
.modal-header{padding:20px 28px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-header h3{font-size:1rem;font-weight:700}
.modal-close{background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text-3);transition:color .2s;width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center}
.modal-close:hover{color:var(--text);background:var(--bg-2)}
.modal-body{padding:28px;overflow-y:auto;flex:1}
.modal-body pre{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius);padding:24px;font-size:0.82rem;line-height:1.7;overflow-x:auto;white-space:pre-wrap;word-break:break-all;color:var(--green);font-family:'JetBrains Mono',monospace}
.modal-footer{padding:16px 28px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px}

/* ═══ FORM INPUTS ═══ */
.form-input{width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--bg-2);color:var(--text);font-size:0.88rem;font-family:Inter,sans-serif;transition:all .2s}
.form-input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(249,115,22,0.1);background:var(--bg)}

/* ═══ FOOTER ═══ */
footer{text-align:center;padding:32px;color:var(--text-3);font-size:0.78rem;border-top:1px solid var(--border)}

/* ═══ RESPONSIVE ═══ */
@media(max-width:1024px){
  .files-grid{grid-template-columns:repeat(2,1fr)}
  .stats-row{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:768px){
  main{padding:88px 16px 60px}
  .files-grid{grid-template-columns:1fr}
  .framework-grid{grid-template-columns:1fr}
  .stats-row{grid-template-columns:1fr 1fr}
  .charts-grid{grid-template-columns:1fr}
  .how-steps{grid-template-columns:1fr}
  .nav-links{display:none}
  .nav-inner{padding:0 16px}
  .progress-section{flex-direction:column;text-align:center}
  .section-header{flex-direction:column;align-items:flex-start}
}
@media(max-width:480px){
  .stats-row{grid-template-columns:1fr}
  .welcome-actions{flex-direction:column}
  .welcome-actions .btn{width:100%;justify-content:center}
}

:root{
  --bg:#ffffff;--bg-2:#fafafa;--bg-3:#f5f5f5;
  --text:#0a0a0a;--text-2:#444444;--text-3:#777777;
  --gold:#C9A227;--gold-light:#E8C547;--gold-dark:#A68521;
  --gold-glow:rgba(201,162,39,0.12);
  --gold-gradient:linear-gradient(135deg,#C9A227,#E8C547,#C9A227);
  --gold-shadow:0 8px 32px rgba(201,162,39,0.25);
  --gold-shadow-lg:0 16px 48px rgba(201,162,39,0.3);
  --green:#16a34a;--blue:#2563eb;--purple:#7c3aed;--red:#dc2626;
  --border:rgba(0,0,0,0.06);--border-2:rgba(0,0,0,0.10);
  --shadow-sm:0 2px 8px rgba(0,0,0,0.04);
  --shadow-md:0 8px 24px rgba(0,0,0,0.06);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.08);
  --shadow-xl:0 24px 64px rgba(0,0,0,0.10);
  --radius:16px;--radius-lg:20px;--radius-xl:28px;
}

/* ═══ PREMIUM GOLD BUTTONS ═══ */
.btn-primary{
  background:var(--gold-gradient)!important;color:#0a0a0a!important;
  box-shadow:var(--gold-shadow)!important;border:none!important;
  position:relative;overflow:hidden;font-weight:700!important;
}
.btn-primary::before{
  content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);
  transition:left .6s ease;
}
.btn-primary:hover::before{left:100%}
.btn-primary:hover{
  transform:translateY(-3px)!important;
  box-shadow:var(--gold-shadow-lg)!important;
}

.btn-secondary,.btn-ghost{
  background:var(--bg)!important;color:var(--text)!important;
  border:1.5px solid var(--border-2)!important;
  box-shadow:var(--shadow-sm)!important;
}
.btn-secondary:hover,.btn-ghost:hover{
  border-color:var(--gold)!important;
  box-shadow:0 4px 16px rgba(201,162,39,0.15)!important;
  transform:translateY(-2px)!important;
}

.btn-green{
  background:linear-gradient(135deg,#16a34a,#22c55e)!important;
  color:#fff!important;box-shadow:0 8px 24px rgba(22,163,74,0.25)!important;
}
.btn-green:hover{
  transform:translateY(-3px)!important;
  box-shadow:0 12px 36px rgba(22,163,74,0.35)!important;
}

.btn-blue{
  background:linear-gradient(135deg,#2563eb,#3b82f6)!important;
  color:#fff!important;box-shadow:0 8px 24px rgba(37,99,235,0.25)!important;
}
.btn-blue:hover{
  transform:translateY(-3px)!important;
  box-shadow:0 12px 36px rgba(37,99,235,0.35)!important;
}

/* ═══ PREMIUM CARDS ═══ */
.file-card,.stat-card,.chart-card,.reports-section,.how-section,.framework-card{
  background:var(--bg)!important;
  border:1.5px solid var(--border)!important;
  transition:all .4s cubic-bezier(0.25,0.46,0.45,0.94)!important;
  position:relative;overflow:hidden;
}
.file-card::after,.stat-card::after,.chart-card::after,.framework-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--gold-gradient);opacity:0;transition:opacity .3s ease;
}
.file-card:hover,.stat-card:hover,.chart-card:hover{
  transform:translateY(-8px)!important;
  box-shadow:var(--shadow-xl)!important;
  border-color:rgba(201,162,39,0.2)!important;
}
.file-card:hover::after,.stat-card:hover::after,.chart-card:hover::after{
  opacity:1;
}

.file-card.done{border-color:rgba(22,163,74,0.25)!important}
.file-card.done::after{background:linear-gradient(90deg,#16a34a,#22c55e)!important}

/* ═══ GOLD ACCENTS ═══ */
.nav-logo-icon{background:var(--gold-gradient)!important;box-shadow:0 4px 14px rgba(201,162,39,0.3)!important}
.nav-logo-text span{color:var(--gold)!important}
.stat-value.orange{color:var(--gold)!important}
.progress-bar-inner{background:var(--gold-gradient)!important}
.file-status.generating{background:var(--gold-glow)!important;color:var(--gold-dark)!important}
.file-status.generating .dot{background:var(--gold)!important}
.file-icon.orange{background:var(--gold-glow)!important}
.framework-badge{background:var(--gold-gradient)!important;color:#0a0a0a!important}
.framework-card.recommended{border-color:var(--gold)!important;box-shadow:var(--gold-shadow)!important}
.framework-card.orange::before{background:var(--gold-gradient)!important}
.sidebar-logo-icon{background:var(--gold-gradient)!important}

