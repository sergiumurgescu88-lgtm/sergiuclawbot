            <div class="framework-desc">Framework matur, stabil, production-ready</div>
          </div>
        </div>
        <ul class="framework-features">
          <li><span class="check">✓</span> Agent single-thread, rapid și predictibil</li>
          <li><span class="check">✓</span> Configurare simplă, fără dependențe complexe</li>
          <li><span class="check">✓</span> Ideal pentru MVP-uri și business-uri mici</li>
          <li><span class="check">✓</span> Comunitate activă, documentație solidă</li>
        </ul>
        <button onclick="window.open('https://vlad.neoterm.ro','_blank')" class="btn btn-blue" style="width:100%;justify-content:center">🧪 Testează OpenClaw Live →</button>
      </div>

      <!-- HERMES -->
      <div class="framework-card orange recommended fade-in-2">
        <div class="framework-badge">Recomandat</div>
        <div class="framework-header">
          <div class="framework-icon orange-icon">🦉</div>
          <div>
            <div class="framework-name">Hermes Agent</div>
            <div class="framework-desc">Learning loop nativ, multi-agent, enterprise</div>
