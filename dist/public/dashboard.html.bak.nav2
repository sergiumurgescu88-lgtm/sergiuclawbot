</div>

<!-- ═══ REPORT CONFIG MODAL ═══ -->
<div class="modal-overlay" id="reportConfigModal">
  <div class="modal" style="max-width:560px">
    <div class="modal-header">
      <h3>⚙️ Configurare Rapoarte Automate</h3>
      <button class="modal-close" onclick="closeModal('reportConfigModal')">×</button>
    </div>
    <div class="modal-body">
      <p style="color:var(--text-2);font-size:0.85rem;margin-bottom:24px">Configurează unde și cum vrei să primești rapoartele săptămânale automate (în fiecare luni la 09:00).</p>
      <div style="margin-bottom:20px">
        <label style="display:block;font-size:0.82rem;font-weight:600;margin-bottom:6px">Nume Business</label>
        <input type="text" id="cfgBusinessName" class="form-input" placeholder="ex: Restaurant La Crama">
      </div>
      <div style="margin-bottom:20px">
        <label style="display:block;font-size:0.82rem;font-weight:600;margin-bottom:6px">📧 Email pentru rapoarte <span style="color:var(--text-3);font-weight:400">(opțional)</span></label>
        <input type="email" id="cfgEmail" class="form-input" placeholder="nume@business.ro">
      </div>
      <div style="margin-bottom:20px">
        <label style="display:block;font-size:0.82rem;font-weight:600;margin-bottom:6px">📱 Telegram Bot Token <span style="color:var(--text-3);font-weight:400">(opțional)</span></label>
        <input type="text" id="cfgTelegramToken" class="form-input" placeholder="ex: 123456:ABC-DEF...">
      </div>
      <div style="margin-bottom:20px">
        <label style="display:block;font-size:0.82rem;font-weight:600;margin-bottom:6px">📱 Telegram Chat ID <span style="color:var(--text-3);font-weight:400">(opțional)</span></label>
        <input type="text" id="cfgTelegramChatId" class="form-input" placeholder="ex: 987654321">
      </div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px">
        <input type="checkbox" id="cfgEnabled" checked style="accent-color:var(--accent);width:18px;height:18px">
        <label for="cfgEnabled" style="font-size:0.85rem;font-weight:500">Rapoarte automate activate (luni 09:00)</label>
      </div>
      <div id="reportConfigStatus" style="padding:10px 14px;border-radius:8px;font-size:0.82rem;text-align:center;min-height:16px"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('reportConfigModal')">Anulează</button>
      <button class="btn btn-primary" onclick="saveReportConfig()" id="saveConfigBtn">💾 Salvează</button>
    </div>
  </div>
</div>

<footer>© 2026 AgentulMeu.online · Made in România 🇷🇴</footer>

<script>
// ═══ AUTH & INIT ═══
const token = localStorage.getItem('agentulmeu_token');
if (!token) window.location.href = '/login?redirect=/dashboard';

let userData = null;
try {
  const parts = token.split('.');
  const payload = JSON.parse(atob(parts[1].replace(/-/g,'+').replace(/_/g,'/') + '=='));
  userData = payload;
} catch(e) {}

function logout() {
  localStorage.removeItem('agentulmeu_token');
  window.location.href = '/login';
}

// Update user info
const userName = document.getElementById('userName');
const navAvatar = document.getElementById('navAvatar');
if (userData) {
  const name = userData.name || userData.username || 'Utilizator';
  userName.textContent = name;
  navAvatar.textContent = name.charAt(0).toUpperCase();
}

// Nav scroll effect
window.addEventListener('scroll', () => {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
});

// ═══ FILE TYPES ═══
const FILE_TYPES = [
  { key: 'SOUL', icon: '🎯', name: 'Personalitate & Reguli', desc: 'Misiune, valori, reguli absolute, autonomie', color: 'orange' },
  { key: 'IDENTITY', icon: '🪪', name: 'Cartea de Identitate', desc: 'Profil agent, ton, limbă, program de lucru', color: 'blue' },
  { key: 'USER', icon: '👤', name: 'Profilul Tău', desc: 'Preferințe, priorități 90 zile, stil comunicare', color: 'purple' },
  { key: 'MEMORY', icon: '🧠', name: 'Cunoștințe Business', desc: 'Produse, prețuri, USP, contexte importante', color: 'orange' },
  { key: 'TOOLS', icon: '🛠️', name: 'Canale & Integrări', desc: 'Telegram, WhatsApp, CRM, API-uri, buget', color: 'blue' },
  { key: 'AGENTS', icon: '🤖', name: 'Echipa de Sub-Agenți', desc: 'Workflow-uri, pipeline, delegare task-uri', color: 'purple' },
  { key: 'HEARTBEAT', icon: '💓', name: 'Task-uri Automate', desc: 'Rutine, trigger-e, alerte, follow-up', color: 'orange' },
  { key: 'BOOTSTRAP', icon: '🚀', name: 'Checklist Lansare', desc: 'Pași critici, fallback plan, verificări', color: 'green' },
  { key: 'AGENT_RD', icon: '🔬', name: 'Research & Idei', desc: 'Framework validare, surse, testare idei', color: 'blue' }
];

const fileStates = {};
const fileContents = {};

function renderFiles() {
  const grid = document.getElementById('filesGrid');
  grid.innerHTML = FILE_TYPES.map(ft => {
    const state = fileStates[ft.key] || 'pending';
    const statusClass = state === 'done' ? 'done' : state === 'generating' ? 'generating' : 'pending';
    const statusText = state === 'done' ? '✓ Generat' : state === 'generating' ? '<span class="dot"></span> Se generează...' : 'Negenerat';
    const iconClass = state === 'done' ? 'green' : ft.color;
    
    return `
      <div class="file-card ${statusClass}" id="card-${ft.key}">
        <div class="file-icon ${iconClass}">${ft.icon}</div>
        <div class="file-name">${ft.name}</div>
        <div class="file-desc">${ft.desc}</div>
        <div class="file-status ${statusClass}">${statusText}</div>
        <div class="file-actions">
          ${state === 'done' ? `
            <button class="btn btn-ghost btn-sm" onclick="previewFile('${ft.key}')">👁 Preview</button>
            <button class="btn btn-green btn-sm" onclick="downloadSingle('${ft.key}')">📥 Descarcă</button>
          ` : state === 'generating' ? `
            <button class="btn btn-ghost btn-sm" disabled>⏳ Se generează...</button>
          ` : `
            <button class="btn btn-primary btn-sm" onclick="generateSingle('${ft.key}')">⚡ Generează</button>
          `}
        </div>
      </div>
    `;
  }).join('');
}

renderFiles();

// ═══ GENERATE SINGLE ═══
async function generateSingle(key) {
  fileStates[key] = 'generating';
  renderFiles();
  updateProgress();
  
  try {
    const r = await fetch('/api/generate-file', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token
      },
      body: JSON.stringify({ file_type: key, intake_data: {} })
    });
    const d = await r.json();
    if (d.content) {
      fileStates[key] = 'done';
      fileContents[key] = d.content;
    } else {
      fileStates[key] = 'pending';
    }
  } catch(e) {
    fileStates[key] = 'pending';
  }
  renderFiles();
  updateProgress();
}

// ═══ GENERATE ALL ═══
async function generateAll() {
  const btn = document.getElementById('generateAllBtn');
  btn.disabled = true;
  
  try {
    const r = await fetch('/api/generate-zip', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token
      },
      body: JSON.stringify({ intake_data: {} })
    });
    const d = await r.json();
    
    if (d.job_id) {
      document.getElementById('progressSection').style.display = 'flex';
      await pollJob(d.job_id);
    }
  } catch(e) {
    console.error('Generate all error:', e);
  }
  btn.disabled = false;
}

async function pollJob(jobId) {
  const maxAttempts = 120;
  for (let i = 0; i < maxAttempts; i++) {
    try {
      const r = await fetch(`/api/job/${jobId}/result`, {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      const d = await r.json();
      
      const done = d.done || 0;
      const total = d.total || 9;
      const pct = Math.round((done / total) * 100);
      
      document.getElementById('progressBar').style.width = pct + '%';
      document.getElementById('progressCount').textContent = done + '/' + total;
      document.getElementById('progressStatus').textContent = d.status === 'done' ? 'Complet!' : `Se generează... ${done}/${total}`;
      
      if (d.status === 'done') {
        document.getElementById('progressBar').classList.remove('generating');
        document.getElementById('progressLabel').textContent = '✓ Generare completă!';
        
        if (d.files) {
          Object.keys(d.files).forEach(key => {
            if (d.files[key].ok) {
              fileStates[key] = 'done';
              fileContents[key] = d.files[key].content || '';
            }
          });
        }
        
        if (d.zip_b64) {
          const zipBtn = document.getElementById('downloadZipBtn');
          zipBtn.disabled = false;
          zipBtn.textContent = `📦 Descarcă ZIP (${total}/9)`;
          zipBtn.onclick = () => {
            const link = document.createElement('a');
            link.href = 'data:application/zip;base64,' + d.zip_b64;
            link.download = 'agentulmeu-config.zip';
            link.click();
          };
        }
        
        renderFiles();
        setTimeout(() => {
          document.getElementById('progressSection').style.display = 'none';
        }, 3000);
        break;
      }
      
      document.getElementById('progressBar').classList.add('generating');
      
    } catch(e) {}
    await new Promise(r => setTimeout(r, 3000));
  }
}

function updateProgress() {
  const done = Object.values(fileStates).filter(s => s === 'done').length;
  const zipBtn = document.getElementById('downloadZipBtn');
  zipBtn.textContent = `📦 Descarcă ZIP (${done}/9)`;
  zipBtn.disabled = done === 0;
  
  const genBtn = document.getElementById('generateAllBtn');
  const remaining = 9 - done;
  genBtn.textContent = `🔄 Generează Toate (${remaining} rămase)`;
}

// ═══ PREVIEW & DOWNLOAD ═══
function previewFile(key) {
  const ft = FILE_TYPES.find(f => f.key === key);
  document.getElementById('previewTitle').textContent = ft.icon + ' ' + ft.name;
  document.getElementById('previewContent').textContent = fileContents[key] || 'Conținut indisponibil.';
  document.getElementById('previewDownloadBtn').onclick = () => downloadSingle(key);
  document.getElementById('previewModal').classList.add('active');
}

function downloadSingle(key) {
  const content = fileContents[key] || '';
  const blob = new Blob([content], { type: 'text/markdown' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = key + '.md';
  a.click();
  URL.revokeObjectURL(url);
}

function downloadFile() {
  // Handled by individual buttons
}

function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}

// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) overlay.classList.remove('active');
  });
});

// ═══ REPORTS ═══
const INTENT_LABELS = {
  'rezervare': '📅 Rezervări', 'pret': '💰 Prețuri', 'suport': '🛠️ Suport',
  'vanzare': '🛒 Vânzări', 'meniu': '🍽️ Meniu', 'program': '🕐 Program',
  'contact': '📍 Contact', 'general': '💬 General'
};
const INTENT_COLORS = {
  'rezervare': '#f97316', 'pret': '#16a34a', 'suport': '#2563eb',
  'vanzare': '#7c3aed', 'meniu': '#ec4899', 'program': '#14b8a6',
  'contact': '#eab308', 'general': '#6b7280'
};

async function loadReportsData() {
  try {
    const r = await fetch('/api/reports/weekly', {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await r.json();
    if (data.success) {
      renderReportStats(data);
      renderIntentsChart(data);
      renderChannelsChart(data);
      renderDailyChart(data);
      renderTopQuestions(data);
    }
  } catch(e) { console.error('Reports load error:', e); }
}

function renderReportStats(data) {
  const roi = data.roi || {};
  document.getElementById('rptTotalConv').textContent = data.total_conversations || 0;
  document.getElementById('rptHoursSaved').textContent = (roi.hours_saved || 0) + 'h';
  document.getElementById('rptAppointments').textContent = roi.appointments || 0;
  document.getElementById('rptValueLei').textContent = Math.round(roi.estimated_value_lei || 0) + ' lei';
}

function renderIntentsChart(data) {
  const container = document.getElementById('intentsChart');
  if (!data.intents || data.intents.length === 0) return;
  const maxCount = Math.max(...data.intents.map(i => i.count));
  container.innerHTML = data.intents.map(item => {
    const label = INTENT_LABELS[item.intent] || item.intent;
    const color = INTENT_COLORS[item.intent] || '#6b7280';
    const pct = data.total_conversations > 0 ? Math.round((item.count / data.total_conversations) * 100) : 0;
    const barWidth = maxCount > 0 ? Math.round((item.count / maxCount) * 100) : 0;
    return `<div class="chart-bar"><div class="chart-bar-header"><span class="chart-bar-label">${label}</span><span class="chart-bar-value">${item.count} (${pct}%)</span></div><div class="chart-bar-track"><div class="chart-bar-fill" style="width:${barWidth}%;background:${color}"></div></div></div>`;
  }).join('');
}

function renderChannelsChart(data) {
  const container = document.getElementById('channelsChart');
  if (!data.channels || data.channels.length === 0) return;
  const maxCount = Math.max(...data.channels.map(c => c.count));
  const channelColors = { 'telegram': '#2563eb', 'whatsapp': '#16a34a', 'web': '#f97316', 'discord': '#7c3aed', 'unknown': '#6b7280' };
  container.innerHTML = data.channels.map(ch => {
    const color = channelColors[ch.channel] || '#6b7280';
    const pct = data.total_conversations > 0 ? Math.round((ch.count / data.total_conversations) * 100) : 0;
    const barWidth = maxCount > 0 ? Math.round((ch.count / maxCount) * 100) : 0;
    return `<div class="chart-bar"><div class="chart-bar-header"><span class="chart-bar-label">${ch.channel.charAt(0).toUpperCase() + ch.channel.slice(1)}</span><span class="chart-bar-value">${ch.count} (${pct}%)</span></div><div class="chart-bar-track"><div class="chart-bar-fill" style="width:${barWidth}%;background:${color}"></div></div></div>`;
  }).join('');
}

function renderDailyChart(data) {
  const container = document.getElementById('dailyChart');
  if (!data.daily || data.daily.length === 0) return;
  const maxCount = Math.max(...data.daily.map(d => d.count));
  const dayNames = ['Dum', 'Lun', 'Mar', 'Mie', 'Joi', 'Vin', 'Sâm'];
  const sorted = [...data.daily].sort((a, b) => new Date(a.day) - new Date(b.day));
  container.innerHTML = '<div class="daily-chart">' + sorted.map(d => {
    const date = new Date(d.day);
    const dayName = dayNames[date.getDay()];
    const barHeight = maxCount > 0 ? Math.round((d.count / maxCount) * 100) : 4;
    return `<div class="daily-bar"><span class="daily-bar-value">${d.count}</span><div class="daily-bar-track" style="height:${Math.max(barHeight, 4)}%;background:var(--accent)"></div><span class="daily-bar-label">${dayName}</span></div>`;
  }).join('') + '</div>';
}

function renderTopQuestions(data) {
  const container = document.getElementById('topQuestions');
  if (!data.top_questions || data.top_questions.length === 0) return;
  container.innerHTML = '<div class="top-questions">' + data.top_questions.map((q, i) => {
    return `<div class="top-question"><div class="rank">${i + 1}</div><div class="text">${q.message}</div><div class="count">${q.count}x</div></div>`;
  }).join('') + '</div>';
}

// ═══ REPORT CONFIG ═══
function openReportConfig() {
  document.getElementById('reportConfigModal').classList.add('active');
  loadReportConfig();
}

async function loadReportConfig() {
  try {
    const r = await fetch('/api/reports/config', {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await r.json();
    if (data.success && data.config) {
      document.getElementById('cfgBusinessName').value = data.config.business_name || '';
      document.getElementById('cfgEmail').value = data.config.email || '';
      document.getElementById('cfgTelegramToken').value = data.config.telegram_token || '';
      document.getElementById('cfgTelegramChatId').value = data.config.telegram_chat_id || '';
      document.getElementById('cfgEnabled').checked = data.config.enabled !== false;
    }
  } catch(e) {}
}

async function saveReportConfig() {
  const btn = document.getElementById('saveConfigBtn');
  const status = document.getElementById('reportConfigStatus');
  btn.disabled = true; btn.textContent = '⏳ Se salvează...'; status.textContent = '';
  
  try {
    const r = await fetch('/api/reports/configure', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({
        business_name: document.getElementById('cfgBusinessName').value,
        email: document.getElementById('cfgEmail').value,
        telegram_token: document.getElementById('cfgTelegramToken').value,
        telegram_chat_id: document.getElementById('cfgTelegramChatId').value,
        enabled: document.getElementById('cfgEnabled').checked
      })
    });
    const data = await r.json();
    if (data.success) {
      status.textContent = '✓ Configurație salvată!';
      status.style.background = 'rgba(22,163,74,0.06)';
      status.style.border = '1px solid rgba(22,163,74,0.15)';
      status.style.color = '#16a34a';
      setTimeout(() => closeModal('reportConfigModal'), 1500);
    } else {
      status.textContent = '✕ ' + (data.error || 'Eroare');
      status.style.background = 'rgba(220,38,38,0.06)';
      status.style.border = '1px solid rgba(220,38,38,0.15)';
      status.style.color = '#dc2626';
    }
  } catch(e) {
    status.textContent = '✕ Eroare de conexiune';
    status.style.background = 'rgba(220,38,38,0.06)';
    status.style.color = '#dc2626';
  }
  btn.disabled = false; btn.textContent = '💾 Salvează';
}

async function sendTestReport() {
  const btn = event.target;
  btn.disabled = true; btn.textContent = '⏳ Se trimite...';
  try {
    const cfgR = await fetch('/api/reports/config', { headers: { 'Authorization': 'Bearer ' + token } });
    const cfgData = await cfgR.json();
    if (!cfgData.success || !cfgData.config) { alert('Configurează mai întâi rapoartele.'); btn.disabled = false; btn.textContent = '📤 Trimite Test'; return; }
    const cfg = cfgData.config;
    let sent = false;
    if (cfg.telegram_token && cfg.telegram_chat_id) {
      const r = await fetch('/api/reports/send-telegram', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ telegram_token: cfg.telegram_token, chat_id: cfg.telegram_chat_id, business_name: cfg.business_name })
      });
      const data = await r.json();
      if (data.success) { alert('✓ Raport trimis pe Telegram!'); sent = true; }
      else alert('✕ Telegram: ' + (data.error || 'Eroare'));
    }
    if (cfg.email && !sent) {
      const r = await fetch('/api/reports/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ email: cfg.email, business_name: cfg.business_name })
      });
      const data = await r.json();
      if (data.success) { alert('✓ Raport trimis pe email!'); sent = true; }
      else alert('✕ Email: ' + (data.error || 'Eroare'));
    }
    if (!sent) alert('Niciun canal configurat.');
  } catch(e) { alert('Eroare: ' + e.message); }
  btn.disabled = false; btn.textContent = '📤 Trimite Test';
}

function exportPDF() {
  const printContent = document.getElementById('reportsSection');
  const printWindow = window.open('', '_blank');
  printWindow.document.write(`<!DOCTYPE html><html><head><title>Raport AgentulMeu — ${new Date().toLocaleDateString('ro-RO')}</title><style>body{font-family:Arial,sans-serif;background:#fff;color:#111;padding:32px;max-width:800px;margin:0 auto}h2{color:#f97316;font-size:20px;margin-bottom:8px}h3{font-size:14px;margin:16px 0 8px}p{color:#666;font-size:13px}.stat{display:inline-block;margin-right:24px;margin-bottom:16px}.stat-val{font-size:24px;font-weight:800;color:#f97316}.stat-label{font-size:11px;color:#888}.bar-container{margin-bottom:10px}.bar-label{font-size:12px;font-weight:600}.bar-value{font-size:11px;color:#888}.bar-bg{height:6px;background:#eee;border-radius:3px;margin-top:2px}.bar-fill{height:100%;border-radius:3px}.question{padding:6px 0;border-bottom:1px solid #eee;font-size:12px}.footer{margin-top:32px;text-align:center;color:#aaa;font-size:10px}
:root{
  --bg:#ffffff;--bg-2:#fafafa;--bg-3:#f5f5f5;
  --text:#0a0a0a;--text-2:#444444;--text-3:#777777;
  --gold:#C9A227;--gold-light:#E8C547;--gold-dark:#A68521;
  --gold-glow:rgba(201,162,39,0.12);
  --gold-gradient:linear-gradient(135deg,#C9A227,#E8C547,#C9A227);
  --gold-shadow:0 8px 32px rgba(201,162,39,0.25);
  --gold-shadow-lg:0 16px 48px rgba(201,162,39,0.3);
  --green:#16a34a;--blue:#2563eb;--purple:#7c3aed;--red:#dc2626;
  --border:rgba(0,0,0,0.06);--border-2:rgba(0,0,0,0.10);
  --shadow-sm:0 2px 8px rgba(0,0,0,0.04);
  --shadow-md:0 8px 24px rgba(0,0,0,0.06);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.08);
  --shadow-xl:0 24px 64px rgba(0,0,0,0.10);
  --radius:16px;--radius-lg:20px;--radius-xl:28px;
}

/* ═══ PREMIUM GOLD BUTTONS ═══ */
.btn-primary{
  background:var(--gold-gradient)!important;color:#0a0a0a!important;
  box-shadow:var(--gold-shadow)!important;border:none!important;
  position:relative;overflow:hidden;font-weight:700!important;
}
.btn-primary::before{
  content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);
  transition:left .6s ease;
}
.btn-primary:hover::before{left:100%}
.btn-primary:hover{
  transform:translateY(-3px)!important;
  box-shadow:var(--gold-shadow-lg)!important;
}

.btn-secondary,.btn-ghost{
  background:var(--bg)!important;color:var(--text)!important;
  border:1.5px solid var(--border-2)!important;
  box-shadow:var(--shadow-sm)!important;
}
.btn-secondary:hover,.btn-ghost:hover{
  border-color:var(--gold)!important;
  box-shadow:0 4px 16px rgba(201,162,39,0.15)!important;
  transform:translateY(-2px)!important;
}

.btn-green{
  background:linear-gradient(135deg,#16a34a,#22c55e)!important;
  color:#fff!important;box-shadow:0 8px 24px rgba(22,163,74,0.25)!important;
}
.btn-green:hover{
  transform:translateY(-3px)!important;
  box-shadow:0 12px 36px rgba(22,163,74,0.35)!important;
}

.btn-blue{
  background:linear-gradient(135deg,#2563eb,#3b82f6)!important;
  color:#fff!important;box-shadow:0 8px 24px rgba(37,99,235,0.25)!important;
}
.btn-blue:hover{
  transform:translateY(-3px)!important;
  box-shadow:0 12px 36px rgba(37,99,235,0.35)!important;
}

/* ═══ PREMIUM CARDS ═══ */
.file-card,.stat-card,.chart-card,.reports-section,.how-section,.framework-card{
  background:var(--bg)!important;
  border:1.5px solid var(--border)!important;
  transition:all .4s cubic-bezier(0.25,0.46,0.45,0.94)!important;
  position:relative;overflow:hidden;
}
.file-card::after,.stat-card::after,.chart-card::after,.framework-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--gold-gradient);opacity:0;transition:opacity .3s ease;
}
.file-card:hover,.stat-card:hover,.chart-card:hover{
  transform:translateY(-8px)!important;
  box-shadow:var(--shadow-xl)!important;
  border-color:rgba(201,162,39,0.2)!important;
}
.file-card:hover::after,.stat-card:hover::after,.chart-card:hover::after{
  opacity:1;
}

.file-card.done{border-color:rgba(22,163,74,0.25)!important}
.file-card.done::after{background:linear-gradient(90deg,#16a34a,#22c55e)!important}

