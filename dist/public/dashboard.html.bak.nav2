      </div>
      <div class="section-actions">
        <button class="btn btn-primary" id="generateAllBtn" onclick="generateAll()">🔄 Generează Toate (9 rămase)</button>
        <button class="btn btn-green" id="downloadZipBtn" onclick="downloadZip()" disabled>📦 Descarcă ZIP (0/9)</button>
      </div>
    </div>

    <!-- PROGRESS -->
    <div class="progress-section" id="progressSection" style="display:none">
      <div class="progress-info">
        <div class="label" id="progressLabel">Se generează...</div>
        <div class="progress-bar-outer">
          <div class="progress-bar-inner" id="progressBar" style="width:0%"></div>
        </div>
        <div class="progress-status" id="progressStatus">Se pregătește generarea...</div>
      </div>
