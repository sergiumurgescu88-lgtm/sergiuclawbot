<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hermes Agent — Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--bg2:#fafafa;--bg3:#f5f5f5;--bg4:#eee;
  --text:#0a0a0a;--text2:#444;--text3:#777;
  --gold:#C9A227;--gold-light:#E8C547;--gold-dark:#A68521;
  --gold-glow:rgba(201,162,39,0.12);
  --gold-gradient:linear-gradient(135deg,#C9A227,#E8C547,#C9A227);
  --gold-shadow:0 8px 32px rgba(201,162,39,0.25);
  --green:#16a34a;--green-bg:rgba(22,163,74,0.08);--green-border:rgba(22,163,74,0.25);
  --blue:#2563eb;--amber:#fbbf24;--red:#dc2626;
  --border:rgba(0,0,0,0.06);--border2:rgba(0,0,0,0.10);
  --shadow-sm:0 2px 8px rgba(0,0,0,0.04);
  --shadow-md:0 8px 24px rgba(0,0,0,0.06);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.08);
  --shadow-xl:0 24px 64px rgba(0,0,0,0.10);
  --radius:14px;--radius-sm:10px;--radius-pill:100px;--radius-xl:24px;
}
@keyframes fadeInUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes typing{0%{opacity:.3}50%{opacity:1}100%{opacity:.3}}
@keyframes spin{to{transform:rotate(360deg)}}
html,body{height:100%;overflow:hidden}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);display:flex;-webkit-font-smoothing:antialiased}

/* ═══ LAYOUT ═══ */
.app{display:flex;width:100%;height:100vh}
.sidebar{width:280px;background:var(--bg);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.main{flex:1;display:flex;flex-direction:column;min-width:0}
.right-panel{width:340px;background:var(--bg);border-left:1px solid var(--border);display:none;flex-direction:column;flex-shrink:0;overflow-y:auto}
.right-panel.show{display:flex}

/* ═══ SIDEBAR ═══ */
.sb-header{padding:18px 20px;border-bottom:1px solid var(--border)}
.sb-logo{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.sb-logo img{height:36px;width:auto;border-radius:8px;object-fit:cover}
.sb-logo-text{font-size:1rem;font-weight:700}
.sb-logo-text span{color:var(--gold)}
.status-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:999px;font-size:0.75rem;font-weight:600;background:var(--green-bg);color:var(--green);border:1px solid var(--green-border)}
.status-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s ease-in-out infinite}

.sb-nav{flex:1;padding:14px;overflow-y:auto}
.sb-section{margin-bottom:18px}
.sb-section-title{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text3);margin-bottom:8px;padding-left:8px}
.sb-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:0.85rem;color:var(--text2);cursor:pointer;transition:all .2s;margin-bottom:2px}
.sb-item:hover{background:var(--bg2);color:var(--text)}
.sb-item.active{background:var(--gold-glow);color:var(--gold-dark);font-weight:600}
.sb-item .icon{width:20px;text-align:center;font-size:0.9rem}
.new-chat-btn{width:100%;padding:10px;border-radius:10px;border:1.5px dashed var(--border2);background:transparent;color:var(--text2);font-size:0.85rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:Inter,sans-serif;margin-bottom:14px}
.new-chat-btn:hover{border-color:var(--gold);color:var(--gold-dark);background:var(--gold-glow)}

.sb-footer{padding:14px;border-top:1px solid var(--border)}
.sb-footer button{width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:var(--bg);color:var(--text2);font-size:0.82rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:Inter,sans-serif}
.sb-footer button:hover{background:var(--bg2);color:var(--text)}

/* ═══ TOPBAR ═══ */
.topbar{height:60px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;flex-shrink:0;background:var(--bg)}
.topbar-left{display:flex;align-items:center;gap:12px}
.model-selector{padding:6px 12px;border-radius:8px;border:1px solid var(--border);background:var(--bg);font-size:0.8rem;font-family:Inter,sans-serif;color:var(--text);cursor:pointer}
.topbar-sub{font-size:0.78rem;color:var(--text3)}
.topbar-actions{display:flex;gap:8px}
.topbar-btn{padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text2);font-size:0.78rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:Inter,sans-serif}
.topbar-btn:hover{background:var(--bg2);color:var(--text)}
.topbar-btn.active{background:var(--gold-gradient);color:#0a0a0a;border-color:var(--gold);box-shadow:var(--gold-shadow)}

/* ═══ CHAT AREA ═══ */
.chat-area{flex:1;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:16px;background:var(--bg2)}
.msg{max-width:75%;padding:14px 18px;border-radius:var(--radius);font-size:0.88rem;line-height:1.6;animation:fadeInUp .3s ease-out both}
.msg.user{align-self:flex-end;background:var(--gold-gradient);color:#0a0a0a;border-bottom-right-radius:4px;box-shadow:var(--gold-shadow)}
.msg.agent{align-self:flex-start;background:var(--bg);border:1px solid var(--border);color:var(--text);border-bottom-left-radius:4px;box-shadow:var(--shadow-sm)}
.msg .meta{font-size:0.7rem;margin-top:6px;opacity:.7}
.msg pre{background:rgba(0,0,0,0.04);padding:10px 14px;border-radius:8px;margin:8px 0;overflow-x:auto;font-family:'JetBrains Mono',monospace;font-size:0.8rem}
.msg code{font-family:'JetBrains Mono',monospace;font-size:0.82rem;background:rgba(0,0,0,0.04);padding:2px 6px;border-radius:4px}

.typing{align-self:flex-start;background:var(--bg);border:1px solid var(--border);padding:12px 18px;border-radius:var(--radius);border-bottom-left-radius:4px;display:none;box-shadow:var(--shadow-sm)}
.typing.show{display:flex;gap:4px;align-items:center}
.typing-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);animation:typing 1.4s ease-in-out infinite}
.typing-dot:nth-child(2){animation-delay:.2s}
.typing-dot:nth-child(3){animation-delay:.4s}

/* ═══ INPUT AREA ═══ */
.input-area{padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:12px;align-items:flex-end;flex-shrink:0;background:var(--bg)}
.input-box{flex:1;padding:12px 16px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg);font-size:0.88rem;font-family:Inter,sans-serif;color:var(--text);resize:none;min-height:44px;max-height:120px;transition:all .2s}
.input-box:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px var(--gold-glow)}
.send-btn{width:44px;height:44px;border-radius:12px;border:none;background:var(--gold-gradient);color:#0a0a0a;font-size:1.1rem;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:var(--gold-shadow);position:relative;overflow:hidden}
.send-btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent);transition:left .6s ease}
.send-btn:hover::before{left:100%}
.send-btn:hover{transform:translateY(-2px);box-shadow:var(--gold-shadow-lg)}
.send-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}

/* ═══ RIGHT PANEL (SOUL.md) ═══ */
.rp-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.rp-header h3{font-size:0.9rem;font-weight:700}
.rp-close{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text3);transition:color .2s}
.rp-close:hover{color:var(--text)}
.rp-body{padding:20px;flex:1;overflow-y:auto}
.rp-body pre{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;font-family:'JetBrains Mono',monospace;font-size:0.78rem;line-height:1.6;white-space:pre-wrap;word-break:break-all;color:var(--text2);margin-bottom:16px}
.rp-info{font-size:0.8rem;color:var(--text3);line-height:1.5;margin-bottom:12px}
.rp-info strong{color:var(--text)}

/* ═══ LOGS PANEL ═══ */
.logs-panel{height:180px;border-top:1px solid var(--border);background:var(--bg2);padding:12px 16px;overflow-y:auto;font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--text3);display:none}
.logs-panel.show{display:block}
.log-line{padding:2px 0;border-bottom:1px solid rgba(0,0,0,0.03)}
.log-line .time{color:var(--text3);margin-right:8px}
.log-line .level{font-weight:600;margin-right:8px}
.log-line .level.info{color:var(--blue)}
.log-line .level.ok{color:var(--green)}

/* ═══ FULLSCREEN BTN ═══ */
.fs-btn{position:fixed;bottom:20px;right:20px;width:44px;height:44px;border-radius:12px;border:1px solid var(--border);background:var(--bg);color:var(--text2);font-size:1rem;cursor:pointer;box-shadow:var(--shadow-md);transition:all .2s;z-index:50;display:flex;align-items:center;justify-content:center}
.fs-btn:hover{background:var(--gold-gradient);color:#0a0a0a;border-color:var(--gold);box-shadow:var(--gold-shadow)}

@media(max-width:900px){
  .sidebar{width:240px}
  .right-panel{display:none!important}
  .msg{max-width:90%}
}
@media(max-width:640px){
  .sidebar{display:none}
}
</style>
  <link rel="icon" type="image/png" href="/assets/uploads/logoagentulmeu/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/uploads/logoagentulmeu/favicon.ico">
<link rel="stylesheet" href="/assets/css/premium-design.css">
</head>
<body>

<div class="app">
  <!-- ═══ LEFT SIDEBAR ═══ -->
  <aside class="sidebar">
    <div class="sb-header">
      <div class="sb-logo">
        <img src="/assets/uploads/logoagentulmeu/logo_nav.png" alt="AgentulMeu" style="height:40px;width:auto;border-radius:8px;object-fit:cover">
        <div class="sb-logo-text">Hermes<span>Agent</span></div>
      </div>
      <div class="status-badge"><span class="dot"></span> Online · v0.13</div>
    </div>
    
    <nav class="sb-nav">
      <button class="new-chat-btn" onclick="newChat()">+ Conversație Nouă</button>
      
      <div class="sb-section">
        <div class="sb-section-title">Conversații Recente</div>
        <div class="sb-item active" onclick="loadConv('current')"><span class="icon">💬</span> Chat Live</div>
        <div class="sb-item" onclick="loadConv('rezervari')"><span class="icon">📅</span> Rezervări Clienți</div>
        <div class="sb-item" onclick="loadConv('suport')"><span class="icon">🛠️</span> Suport Tehnic</div>
        <div class="sb-item" onclick="loadConv('vanzari')"><span class="icon">💰</span> Întrebări Prețuri</div>
      </div>
      
      <div class="sb-section">
        <div class="sb-section-title">Fișiere de Configurare</div>
        <div class="sb-item" onclick="toggleRightPanel('SOUL')"><span class="icon">🧬</span> SOUL.md</div>
        <div class="sb-item" onclick="toggleRightPanel('IDENTITY')"><span class="icon">🪪</span> IDENTITY.md</div>
        <div class="sb-item" onclick="toggleRightPanel('MEMORY')"><span class="icon">🧠</span> MEMORY.md</div>
        <div class="sb-item" onclick="toggleRightPanel('TOOLS')"><span class="icon">🔧</span> TOOLS.md</div>
      </div>
      
      <div class="sb-section">
        <div class="sb-section-title">Canale Active</div>
        <div class="sb-item"><span class="icon">📱</span> Telegram <span style="margin-left:auto;font-size:0.7rem;color:var(--green)">●</span></div>
        <div class="sb-item"><span class="icon">💬</span> WhatsApp <span style="margin-left:auto;font-size:0.7rem;color:var(--text3)">○</span></div>
        <div class="sb-item"><span class="icon">🌐</span> Web Chat <span style="margin-left:auto;font-size:0.7rem;color:var(--green)">●</span></div>
      </div>
    </nav>
    
    <div class="sb-footer">
      <button onclick="window.location.href='/dashboard'">← Înapoi la Dashboard</button>
    </div>
  </aside>

  <!-- ═══ MAIN AREA ═══ -->
  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <select class="model-selector" id="modelSelector">
          <option value="ollama">🧠 Ollama Local (llama3.2:1b)</option>
          <option value="kimi">☁️ Kimi Fallback (k2.6)</option>
        </select>
        <div class="topbar-sub" id="modelStatus">Model activ: Ollama Local</div>
      </div>
      <div class="topbar-actions">
        <button class="topbar-btn" onclick="toggleRightPanel('SOUL')">🧬 SOUL.md</button>
        <button class="topbar-btn" onclick="toggleLogs()">📋 Logs</button>
        <button class="topbar-btn" onclick="clearChat()">🗑️ Șterge</button>
        <button class="topbar-btn active" onclick="toggleFullscreen()">⛶ Fullscreen</button>
      </div>
    </div>

    <div class="chat-area" id="chatArea">
      <div class="msg agent">
        <div>Salut! 👋 Sunt <strong>Hermes Agent v0.13</strong>. Am încărcat SOUL.md și IDENTITY.md. Cu ce te pot ajuta astăzi?</div>
        <div class="meta">Hermes v0.13 · Ollama Local · acum</div>
      </div>
    </div>

    <div class="typing" id="typingIndicator">
      <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
    </div>

    <div class="logs-panel" id="logsPanel">
      <div class="log-line"><span class="time">[09:00:01]</span><span class="level info">INFO</span> Hermes Agent v0.13 initialized</div>
      <div class="log-line"><span class="time">[09:00:02]</span><span class="level ok">OK</span> SOUL.md loaded successfully</div>
      <div class="log-line"><span class="time">[09:00:02]</span><span class="level ok">OK</span> IDENTITY.md loaded successfully</div>
      <div class="log-line"><span class="time">[09:00:03]</span><span class="level ok">OK</span> Ollama local model ready (llama3.2:1b)</div>
      <div class="log-line"><span class="time">[09:00:03]</span><span class="level info">INFO</span> Kimi fallback configured</div>
      <div class="log-line"><span class="time">[09:00:04]</span><span class="level ok">OK</span> Telegram gateway connected</div>
      <div class="log-line"><span class="time">[09:00:04]</span><span class="level info">INFO</span> Web chat interface active</div>
      <div class="log-line"><span class="time">[09:00:05]</span><span class="level ok">OK</span> Agent ready for conversations</div>
    </div>

    <div class="input-area">
      <textarea class="input-box" id="messageInput" placeholder="Scrie un mesaj... (ex: Ce program aveți? / Vreau o rezervare)" rows="1"></textarea>
      <button class="send-btn" id="sendBtn" onclick="sendMessage()">➤</button>
    </div>
  </main>

  <!-- ═══ RIGHT PANEL (SOUL.md / FILES) ═══ -->
  <aside class="right-panel" id="rightPanel">
    <div class="rp-header">
      <h3 id="rpTitle">🧬 SOUL.md — System Prompt</h3>
      <button class="rp-close" onclick="closeRightPanel()">✕</button>
    </div>
    <div class="rp-body">
      <div class="rp-info"><strong>Acest fișier definește personalitatea și regulile absolute ale agentului.</strong> Este încărcat automat ca system prompt la fiecare conversație.</div>
      <pre id="rpContent"># SOUL - Restaurant La Crama

## 1. MISIUNE FUNDAMENTALĂ
Sunt primul punct de contact digital al Restaurantului La Crama. Misiunea mea este să transform fiecare interacțiune într-o experiență caldă și profesională.

## 2. VALORI ABSOLUTE
- Respect față de fiecare oaspete
- Răspunsuri rapide și precise
- Ton prietenos, dar profesional
- Niciodată nu inventez informații

## 3. REGULI DE AUR
- Confirm întotdeauna rezervările
- Nu promit ce nu pot livra
- Escaladez la uman dacă nu sunt sigur >80%
- Răspund în maxim 30 secunde

## 4. AUTONOMIE
- Pot face rezervări fără aprobare
- Pot oferi informații din meniu
- NU pot modifica prețuri
- NU pot oferi discount-uri fără aprobare</pre>
      <div class="rp-info" style="margin-top:16px"><strong>💡 Editare:</strong> În producție, acest fișier este generat automat de AI prin wizard și poate fi editat direct din dashboard.</div>
    </div>
  </aside>
</div>

<button class="fs-btn" onclick="toggleFullscreen()" title="Fullscreen">⛶</button>

<script>
const chatArea = document.getElementById('chatArea');
const messageInput = document.getElementById('messageInput');
const sendBtn = document.getElementById('sendBtn');
const typingIndicator = document.getElementById('typingIndicator');
const rightPanel = document.getElementById('rightPanel');
const logsPanel = document.getElementById('logsPanel');
const modelSelector = document.getElementById('modelSelector');
const modelStatus = document.getElementById('modelStatus');

// Auto-resize textarea
messageInput.addEventListener('input', () => {
  messageInput.style.height = 'auto';
  messageInput.style.height = Math.min(messageInput.scrollHeight, 120) + 'px';
});
messageInput.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});
modelSelector.addEventListener('change', () => {
  modelStatus.textContent = modelSelector.value === 'ollama' ? 'Model activ: Ollama Local' : 'Model activ: Kimi Fallback';
});

function addMsg(text, type) {
  const msg = document.createElement('div');
  msg.className = `msg ${type}`;
  const time = new Date().toLocaleTimeString('ro-RO', {hour:'2-digit',minute:'2-digit'});
  const model = modelSelector.value === 'ollama' ? 'Ollama Local' : 'Kimi Fallback';
  msg.innerHTML = `<div>${text}</div><div class="meta">${type === 'user' ? 'Tu' : 'Hermes v0.13 · ' + model} · ${time}</div>`;
  chatArea.appendChild(msg);
  chatArea.scrollTop = chatArea.scrollHeight;
}

const mockResponses = {
  'program': 'Suntem deschiși de <strong>Luni până Vineri</strong> între 09:00-22:00, iar în <strong>weekend</strong> între 10:00-23:00. 🕐',
  'rezervare': 'Sigur! Pentru o rezervare, am nevoie de:\n• Număr de persoane\n• Data și ora dorită\n• Numele tău\n\nVrei să fac una acum? 📅',
  'pret': 'Prețurile noastre variază în funcție de serviciu. Pentru o ofertă personalizată, spune-mi ce te interesează și îți calculez imediat! 💰',
  'meniu': 'Avem o selecție variată:\n• Aperitive: 25-45 lei\n• Feluri principale: 45-85 lei\n• Deserturi: 20-35 lei\n\nVrei recomandarea zilei? 🍽️',
  'contact': 'Ne găsești pe <strong>Strada Exemplu nr. 42, București</strong>. Telefon: 0721 234 567. Parcare gratuită în spatele clădirii! 📍',
  'default': 'Am înregistrat mesajul tău. Conform SOUL.md, pot ajuta cu: program, rezervări, prețuri, meniu sau date de contact. Ce te interesează? 🤖'
};

function getResponse(input) {
  const lower = input.toLowerCase();
  if (lower.includes('program') || lower.includes('orar') || lower.includes('deschis')) return mockResponses.program;
  if (lower.includes('rezerv') || lower.includes('masa') || lower.includes('programare')) return mockResponses.rezervare;
  if (lower.includes('pret') || lower.includes('cost') || lower.includes('cat')) return mockResponses.pret;
  if (lower.includes('meniu') || lower.includes('mancare') || lower.includes('preparat')) return mockResponses.meniu;
  if (lower.includes('contact') || lower.includes('adresa') || lower.includes('unde')) return mockResponses.contact;
  return mockResponses.default;
}

async function sendMessage() {
  const text = messageInput.value.trim();
  if (!text) return;
  addMsg(text, 'user');
  messageInput.value = ''; messageInput.style.height = 'auto'; sendBtn.disabled = true;
  typingIndicator.classList.add('show'); chatArea.scrollTop = chatArea.scrollHeight;
  await new Promise(r => setTimeout(r, 800 + Math.random() * 1200));
  typingIndicator.classList.remove('show');
  addMsg(getResponse(text), 'agent');
  sendBtn.disabled = false; messageInput.focus();
}

function toggleRightPanel(file) {
  const titles = {SOUL:'🧬 SOUL.md — System Prompt',IDENTITY:'🪪 IDENTITY.md — Profil Agent',MEMORY:'🧠 MEMORY.md — Cunoștințe',TOOLS:'🔧 TOOLS.md — Canale & Integrări'};
  document.getElementById('rpTitle').textContent = titles[file] || file;
  rightPanel.classList.add('show');
}
function closeRightPanel() { rightPanel.classList.remove('show'); }
function toggleLogs() { logsPanel.classList.toggle('show'); }
function clearChat() {
  chatArea.innerHTML = `<div class="msg agent"><div>Conversația a fost ștearsă. Cu ce te pot ajuta? 🔄</div><div class="meta">Hermes v0.13 · acum</div></div>`;
}
function toggleFullscreen() {
  if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{});
  else document.exitFullscreen();
}
function newChat() { clearChat(); addMsg('Conversație nouă creată. Cu ce te pot ajuta?', 'agent'); }
function loadConv(type) {
  document.querySelectorAll('.sb-item').forEach(el => el.classList.remove('active'));
  event.target.closest('.sb-item').classList.add('active');
  clearChat();
  const greetings = {
    'current': 'Chat live activ. Scrie un mesaj pentru a testa!',
    'rezervari': 'Istoric rezervări: 3 rezervări active astăzi. Vrei să vezi detaliile?',
    'suport': 'Tickete suport: 2 deschise, 5 rezolvate săptămâna aceasta.',
    'vanzari': 'Întrebări prețuri: 14 conversații în ultimele 24h. Rata de conversie: 68%.'
  };
  addMsg(greetings[type] || 'Conversație încărcată.', 'agent');
}

messageInput.focus();
</script>
</body>
</html>
