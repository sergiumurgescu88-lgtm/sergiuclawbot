<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checkout — AgentulMeu</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#fff;--bg-2:#f8f9fa;--text:#111;--text-2:#555;--text-3:#888;--accent:#C9A227;--accent-2:#E8C547;--green:#16a34a;--border:rgba(0,0,0,0.06);--border-2:rgba(0,0,0,0.10);--shadow-lg:0 12px 40px rgba(0,0,0,0.08);--shadow-float:0 24px 80px rgba(201,162,39,0.15),0 8px 24px rgba(0,0,0,0.06);--radius:16px;--radius-lg:20px;--radius-xl:28px}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased;line-height:1.6}
.float{animation:float 6s ease-in-out infinite}
.fade-in{animation:fadeInUp .5s ease-out both}

nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--accent),var(--accent-2));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;color:#fff;box-shadow:0 4px 12px rgba(249,115,22,0.3)}
.nav-logo-text{font-size:1.05rem;font-weight:700;color:var(--text)}
.nav-logo-text span{color:var(--accent)}
.nav-links{display:flex;align-items:center;gap:24px}
.nav-links a{color:var(--text-2);text-decoration:none;font-size:0.88rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.btn-nav{padding:8px 18px;border-radius:10px;font-size:0.85rem;font-weight:600;text-decoration:none;transition:all .2s}
.btn-nav-ghost{color:var(--text);border:1px solid var(--border-2);background:transparent}
.btn-nav-ghost:hover{border-color:var(--text)}

main{flex:1;padding:88px 24px 60px;max-width:600px;margin:0 auto;width:100%}

.checkout-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-xl);padding:40px;box-shadow:var(--shadow-lg);animation:fadeInUp .5s ease-out both;transition:all .4s ease}
.checkout-card:hover{box-shadow:var(--shadow-float)}

.plan-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(201,162,39,0.08);border:1px solid rgba(201,162,39,0.15);border-radius:999px;padding:6px 16px;font-size:0.82rem;font-weight:700;color:var(--accent);margin-bottom:20px}
h1{font-size:1.6rem;font-weight:800;letter-spacing:-0.03em;margin-bottom:6px}
.subtitle{color:var(--text-2);font-size:0.92rem;margin-bottom:28px}

.price-display{background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;text-align:center;margin-bottom:28px}
.price-display .amount{font-size:2.4rem;font-weight:900;letter-spacing:-0.03em;color:var(--accent)}
.price-display .period{color:var(--text-3);font-size:0.88rem;margin-top:4px}

.features-list{list-style:none;margin-bottom:28px}
.features-list li{padding:10px 0;font-size:0.88rem;color:var(--text-2);display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}
.features-list li:last-child{border:none}
.features-list .check{color:var(--green);font-weight:700;font-size:1rem}

.btn-checkout{display:block;width:100%;padding:16px;border-radius:14px;border:none;font-size:1rem;font-weight:700;cursor:pointer;transition:all .3s ease;font-family:Inter,sans-serif;background:var(--accent);color:#fff;box-shadow:0 4px 12px rgba(201,162,39,0.25)}
.btn-checkout:hover{background:var(--accent-2);transform:translateY(-2px);box-shadow:0 6px 20px rgba(201,162,39,0.35)}
.btn-checkout:disabled{opacity:.5;cursor:not-allowed;transform:none!important}

.secure-note{text-align:center;margin-top:16px;font-size:0.78rem;color:var(--text-3);display:flex;align-items:center;justify-content:center;gap:6px}

footer{text-align:center;padding:24px;color:var(--text-3);font-size:0.75rem;border-top:1px solid var(--border)}

@media(max-width:600px){
  .nav-links{display:none}
  .checkout-card{padding:28px 20px}
}
</style>
  
  <link rel="icon" type="image/png" href="/assets/uploads/logoagentulmeu/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/uploads/logoagentulmeu/favicon.ico">
<link rel="stylesheet" href="/assets/css/premium-design.css">
<link rel="stylesheet" href="/assets/css/global-nav.css">
</head>
<body>
<nav class="global-nav" id="globalNav">
  <div class="nav-container">
    <a href="/" class="nav-logo">Agentul<span class="logo-accent">Meu</span></a>
    <div class="nav-links desktop-only">
      <a href="/wizard-form">Wizard</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/install-page">Instalare</a>
      <a href="/docs">Docs</a>
      <a href="/login">Autentificare</a>
      <a href="/wizard-form" class="nav-cta">Începe Gratuit</a>
    </div>
    <button class="hamburger mobile-only" id="navToggle" aria-label="Meniu">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/wizard-form">🪄 Wizard</a>
    <a href="/dashboard">📊 Dashboard</a>
    <a href="/install-page">⚡ Instalare</a>
    <a href="/docs">📚 Docs</a>
    <a href="/login">🔑 Autentificare</a>
    <a href="/wizard-form" class="mobile-cta">🚀 Începe Gratuit</a>
  </div>
  <div class="nav-overlay" id="navOverlay"></div>
</nav>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      
      <div class="nav-logo-text">Agentul<span>Meu</span></div>
    </a>
    <div class="nav-links">
      <a href="/">Acasă</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/login" class="btn-nav btn-nav-ghost">Autentificare</a>
    </div>
  </div>
</nav>

<main>
  <div class="checkout-card">
    <div class="plan-badge" id="planBadge">📦 Se încarcă...</div>
    <h1>Finalizează comanda</h1>
    <p class="subtitle">Activează-ți planul și începe să-ți construiești agentul AI.</p>
    
    <div class="price-display">
      <div class="amount" id="priceAmount">—</div>
      <div class="period" id="pricePeriod">—</div>
    </div>
    
    <ul class="features-list" id="featuresList">
      <li><span class="check">✓</span> Se încarcă detaliile planului...</li>
    </ul>
    
    <button class="btn-checkout" id="checkoutBtn" onclick="startCheckout()">
      🔒 Plătește securizat cu Stripe
    </button>
    
    <div class="secure-note">
      🔒 Plată securizată prin Stripe · Factură automată · Anulezi oricând
    </div>
  </div>
</main>

<footer>© 2026 AgentulMeu.online · Made in România 🇷🇴</footer>

<script>
const PLANS = {
  starter: { name: 'Starter', price: '49 lei', period: '/lună · facturat lunar', features: ['9 fișiere MD generate de AI','1 business configurat','Telegram + Web Chat','Dashboard basic','AI fallback (Kimi)'] },
  professional: { name: 'Professional', price: '149 lei', period: '/lună · facturat lunar', features: ['Tot din Starter','Business-uri nelimitate','Sub-agenți specializați','WhatsApp integrat','Rapoarte săptămânale','Support prioritar'] },
  dfy: { name: 'Done-For-You', price: '499 lei', period: '· plată unică', features: ['Tot din Professional','Instalare pe VPS-ul tău','Configurare completă','Training 1-on-1 (2h)','30 zile support prioritar'] }
};

const urlParams = new URLSearchParams(window.location.search);
const planKey = urlParams.get('plan') || 'starter';
const plan = PLANS[planKey] || PLANS.starter;

document.getElementById('planBadge').textContent = '📦 Plan ' + plan.name;
document.getElementById('priceAmount').textContent = plan.price;
document.getElementById('pricePeriod').textContent = plan.period;
document.getElementById('featuresList').innerHTML = plan.features.map(f => `<li><span class="check">✓</span> ${f}</li>`).join('');

async function startCheckout() {
  const btn = document.getElementById('checkoutBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Se redirecționează către Stripe...';
  
  try {
    const token = localStorage.getItem('agentulmeu_token');
    if (!token) {
      window.location.href = '/login?redirect=/checkout?plan=' + planKey;
      return;
    }
    
    const r = await fetch('/api/stripe/create-checkout', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token
      },
      body: JSON.stringify({ plan: planKey })
    });
    const data = await r.json();
    
    if (data.url) {
      window.location.href = data.url;
    } else {
      alert('Eroare: ' + (data.error || 'Nu s-a putut crea sesiunea de plată'));
      btn.disabled = false;
      btn.textContent = '🔒 Plătește securizat cu Stripe';
    }
  } catch(e) {
    alert('Eroare de conexiune. Încearcă din nou.');
    btn.disabled = false;
    btn.textContent = '🔒 Plătește securizat cu Stripe';
  }
}
</script>
<script src="/assets/js/global-nav.js" defer></script>
</body>
</html>
