<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wizard — Completează Cele 9 Fișiere | AgentulMeu</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fff;--bg2:#fafafa;--bg3:#f5f5f5;--bg4:#eee;
  --text:#0a0a0a;--text2:#444;--text3:#777;
  --gold:#C9A227;--gold-light:#E8C547;--gold-dark:#A68521;
  --gold-glow:rgba(201,162,39,0.12);
  --gold-gradient:linear-gradient(135deg,#C9A227,#E8C547,#C9A227);
  --gold-shadow:0 8px 32px rgba(201,162,39,0.25);
  --gold-shadow-lg:0 16px 48px rgba(201,162,39,0.3);
  --green:#16a34a;--green-bg:rgba(22,163,74,0.08);--green-border:rgba(22,163,74,0.25);
  --blue:#2563eb;--amber:#fbbf24;--red:#dc2626;
  --border:rgba(0,0,0,0.06);--border2:rgba(0,0,0,0.10);
  --shadow-sm:0 2px 8px rgba(0,0,0,0.04);
  --shadow-lg:0 16px 48px rgba(0,0,0,0.08);
  --shadow-xl:0 24px 64px rgba(0,0,0,0.10);
  --radius:14px;--radius-sm:10px;--radius-pill:100px;--radius-xl:24px;
}
@keyframes fadeInUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
@keyframes spin{to{transform:rotate(360deg)}}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased;line-height:1.6}
.fade-in{animation:fadeInUp .4s ease-out both}

/* ═══ SHELL ═══ */
.wz-shell{max-width:720px;margin:0 auto;padding:24px 20px 80px}

/* ═══ HEADER ═══ */
.wz-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.wz-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:var(--text)}
.wz-logo span{color:var(--gold)}
.wz-header-sub{font-size:0.75rem;color:var(--text3);font-weight:500}

/* ═══ PROGRESS ═══ */
.wz-progress{margin-bottom:28px}
.wz-progress-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.wz-progress-label{font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3)}
.wz-step-counter{font-family:'Syne',sans-serif;font-size:0.85rem;font-weight:700;color:var(--gold)}
.wz-progress-bar{height:3px;background:var(--bg4);border-radius:2px;overflow:hidden}
.wz-progress-fill{height:100%;background:var(--gold-gradient);border-radius:2px;transition:width .4s cubic-bezier(0.4,0,0.2,1)}
.wz-step-dots{display:flex;gap:6px;margin-top:10px;justify-content:center}
.wz-dot{width:8px;height:8px;border-radius:50%;background:var(--bg4);transition:all .3s;cursor:pointer}
.wz-dot.active{background:var(--gold);transform:scale(1.4);box-shadow:0 2px 8px rgba(201,162,39,0.3)}
.wz-dot.done{background:var(--green)}

/* ═══ STEPS ═══ */
.wz-step{display:none}
.wz-step.active{display:block;animation:fadeInUp .4s ease-out both}
.wz-step-tag{font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.wz-step-tag::before{content:'';display:inline-block;width:16px;height:1px;background:var(--gold);opacity:.6}
.wz-step-title{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:700;margin-bottom:6px;letter-spacing:-0.02em}
.wz-step-sub{font-size:0.88rem;color:var(--text2);line-height:1.6;margin-bottom:24px}
.wz-sdiv{font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);padding-bottom:8px;border-bottom:1px solid var(--border);margin:20px 0 14px}
.wz-sdiv:first-of-type{margin-top:0}

/* ═══ CARD GRID ═══ */
.wz-card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px;margin-bottom:4px}
.wz-card-grid.wide{grid-template-columns:repeat(auto-fill,minmax(180px,1fr))}
.wz-bcard{border:1.5px solid var(--border);border-radius:var(--radius);padding:14px 12px;cursor:pointer;background:var(--bg);transition:all .2s;text-align:center;position:relative;overflow:hidden}
.wz-bcard::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,162,39,0.06),transparent);opacity:0;transition:opacity .2s}
.wz-bcard:hover::before{opacity:1}
.wz-bcard:hover:not(.sel){border-color:var(--border2);transform:translateY(-2px);box-shadow:var(--shadow-sm)}
.wz-bcard.sel{border-color:var(--gold);background:var(--gold-glow)}
.wz-bcard.sel::after{content:'✓';position:absolute;top:6px;right:8px;font-size:0.7rem;color:var(--gold);font-weight:700}
.wz-bcard .wz-bicon{font-size:1.4rem;margin-bottom:6px;display:block}
.wz-bcard .wz-blabel{font-size:0.8rem;font-weight:600;color:var(--text);line-height:1.3}
.wz-bcard .wz-bsub{font-size:0.72rem;color:var(--text3);margin-top:3px;line-height:1.3}
.wz-bcard.sel .wz-blabel{color:var(--gold-dark)}

/* ═══ ACARD ═══ */
.wz-acard{border:1.5px solid var(--border);border-radius:var(--radius);padding:14px 16px;cursor:pointer;background:var(--bg);transition:all .2s;display:flex;align-items:flex-start;gap:12px;margin-bottom:6px}
.wz-acard:hover:not(.sel){border-color:var(--border2);background:var(--bg2)}
.wz-acard.sel{border-color:var(--green-border);background:var(--green-bg)}
.wz-acard.sel-accent{border-color:var(--gold);background:var(--gold-glow)}
.wz-acard .wz-aicon{font-size:1.2rem;min-width:26px;margin-top:1px}
.wz-acard .wz-aname{font-size:0.85rem;font-weight:600;color:var(--text);line-height:1.3}
.wz-acard .wz-adesc{font-size:0.78rem;color:var(--text2);margin-top:2px;line-height:1.5}
.wz-acard.sel .wz-aname{color:var(--green)}
.wz-acard.sel-accent .wz-aname{color:var(--gold-dark)}

/* ═══ PILLS ═══ */
.wz-pill-wrap{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:4px}
.wz-pill{padding:7px 14px;border-radius:var(--radius-pill);border:1.5px solid var(--border);font-size:0.78rem;font-weight:500;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .2s;user-select:none;white-space:nowrap}
.wz-pill:hover:not(.sel){border-color:var(--border2);color:var(--text)}
.wz-pill.sel{background:var(--gold-glow);color:var(--gold-dark);border-color:var(--gold)}

/* ═══ FIELDS ═══ */
.wz-field-wrap{margin-bottom:16px}
.wz-field-label{font-size:0.85rem;font-weight:600;color:var(--text);margin-bottom:4px;display:flex;align-items:center;justify-content:space-between;gap:8px}
.wz-field{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--bg);color:var(--text);font-size:0.88rem;font-family:'Inter',sans-serif;line-height:1.5;transition:all .2s}
.wz-field::placeholder{color:var(--text3)}
.wz-field:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px var(--gold-glow);background:var(--bg2)}
textarea.wz-field{min-height:48px;resize:vertical}

/* ═══ ASK AI BUTTON ═══ */
.wz-btn-ask{font-size:0.72rem;background:var(--gold-glow);color:var(--gold-dark);border:1.5px solid rgba(201,162,39,0.25);padding:4px 10px;border-radius:6px;cursor:pointer;transition:all .2s;font-family:'Inter',sans-serif;font-weight:600;display:inline-flex;align-items:center;gap:4px}
.wz-btn-ask:hover{background:var(--gold-gradient);color:#0a0a0a;border-color:var(--gold)}
.wz-btn-ask:disabled{opacity:.5;cursor:not-allowed}
.wz-btn-ask .spinner{width:12px;height:12px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin .8s linear infinite;display:none}
.wz-btn-ask.loading .spinner{display:inline-block}

/* ═══ AI ANSWER ═══ */
.wz-ai-answer{margin-top:8px;padding:12px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:0.82rem;line-height:1.6;color:var(--text2);display:none;animation:fadeInUp .3s ease-out}
.wz-ai-answer.show{display:block}
.wz-ai-answer .wz-ai-label{font-size:0.7rem;font-weight:700;color:var(--gold);margin-bottom:4px}

/* ═══ STATS ROW ═══ */
.wz-stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:20px}
.wz-stat-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:16px 12px;text-align:center}
.wz-stat-n{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--text);line-height:1}
.wz-stat-l{font-size:0.72rem;color:var(--text3);margin-top:4px;font-weight:500}

/* ═══ MD PREVIEW ═══ */
.wz-md-preview{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px 16px;font-size:0.78rem;font-family:'JetBrains Mono',monospace;color:var(--text2);white-space:pre-wrap;line-height:1.7;overflow-y:auto;margin-bottom:10px}
.wz-md-label{font-size:0.72rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--text3);margin-bottom:6px;margin-top:16px}

/* ═══ CODE EDITOR ═══ */
.wz-code-editor{width:100%;min-height:350px;background:var(--bg2);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:0.82rem;padding:16px;border:1.5px solid var(--border);border-radius:var(--radius-sm);line-height:1.6;resize:vertical}
.wz-code-editor:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px var(--gold-glow)}

/* ═══ NAV ═══ */
.wz-nav{display:flex;justify-content:space-between;align-items:center;margin-top:32px;padding-top:20px;border-top:1px solid var(--border)}
.wz-btn{font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;cursor:pointer;border:none;border-radius:var(--radius-sm);padding:10px 20px;transition:all .2s;display:inline-flex;align-items:center;gap:6px}
.wz-btn-back{background:var(--bg3);color:var(--text2);border:1.5px solid var(--border)}
.wz-btn-back:hover{border-color:var(--border2);color:var(--text)}
.wz-btn-next{background:var(--gold-gradient);color:#0a0a0a;padding:11px 24px;font-weight:700;box-shadow:var(--gold-shadow);position:relative;overflow:hidden}
.wz-btn-next::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);transition:left .6s ease}
.wz-btn-next:hover::before{left:100%}
.wz-btn-next:hover{transform:translateY(-2px);box-shadow:var(--gold-shadow-lg)}
.wz-btn-next:disabled{opacity:.5;cursor:not-allowed;transform:none!important}
.wz-btn-action{width:100%;background:var(--gold-gradient);color:#0a0a0a;padding:14px 24px;font-size:0.92rem;font-weight:700;border-radius:var(--radius);box-shadow:var(--gold-shadow);position:relative;overflow:hidden}
.wz-btn-action::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);transition:left .6s ease}
.wz-btn-action:hover::before{left:100%}
.wz-btn-action:hover{transform:translateY(-2px);box-shadow:var(--gold-shadow-lg)}

/* ═══ CHAT WIDGET ═══ */
.wz-chat-toggle{position:fixed;bottom:20px;right:20px;width:56px;height:56px;border-radius:28px;background:var(--gold-gradient);color:#0a0a0a;border:none;cursor:pointer;box-shadow:var(--gold-shadow);font-size:1.4rem;z-index:100;transition:all .2s}
.wz-chat-toggle:hover{transform:translateY(-2px);box-shadow:var(--gold-shadow-lg)}
.wz-chat-panel{position:fixed;bottom:88px;right:20px;width:360px;height:500px;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-xl);display:none;flex-direction:column;overflow:hidden;box-shadow:var(--shadow-xl);z-index:100}
.wz-chat-panel.open{display:flex}
.wz-chat-header{background:var(--bg2);padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.wz-chat-header span{font-weight:700;font-family:'Syne',sans-serif;font-size:0.92rem}
.wz-chat-header button{background:none;border:none;color:var(--text3);cursor:pointer;font-size:1.2rem}
.wz-chat-msgs{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px}
.wz-chat-msg{padding:10px 14px;border-radius:12px;font-size:0.82rem;line-height:1.5;max-width:85%}
.wz-chat-msg.user{background:var(--gold-glow);color:var(--gold-dark);align-self:flex-end;border-bottom-right-radius:4px;border:1px solid rgba(201,162,39,0.15)}
.wz-chat-msg.bot{background:var(--bg3);color:var(--text);align-self:flex-start;border-bottom-left-radius:4px}
.wz-chat-input{padding:12px;border-top:1px solid var(--border);display:flex;gap:8px}
.wz-chat-input input{flex:1;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-size:0.82rem;font-family:'Inter',sans-serif}
.wz-chat-input input:focus{outline:none;border-color:var(--gold)}
.wz-chat-input button{background:var(--gold-gradient);color:#0a0a0a;border:none;border-radius:8px;width:36px;height:36px;cursor:pointer;font-size:1rem;flex-shrink:0}

@media(max-width:600px){
  .wz-card-grid{grid-template-columns:repeat(2,1fr)}
  .wz-card-grid.wide{grid-template-columns:1fr}
  .wz-stats-row{grid-template-columns:1fr}
  .wz-chat-panel{width:calc(100% - 40px);right:20px;left:20px}
}
</style>
  
  <link rel="icon" type="image/png" href="/assets/uploads/logoagentulmeu/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/uploads/logoagentulmeu/favicon.ico">
<link rel="stylesheet" href="/assets/css/premium-design.css">
<link rel="stylesheet" href="/assets/css/global-nav.css">
</head>
<body>
<nav class="global-nav" id="globalNav">
  <div class="nav-container">
    <a href="/" class="nav-logo">Agentul<span class="logo-accent">Meu</span></a>
    <div class="nav-links desktop-only">
      <a href="/wizard-form">Wizard</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/install-page">Instalare</a>
      <a href="/docs">Docs</a>
      <a href="/login">Autentificare</a>
      <a href="/wizard-form" class="nav-cta">Începe Gratuit</a>
    </div>
    <button class="hamburger mobile-only" id="navToggle" aria-label="Meniu">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/wizard-form">🪄 Wizard</a>
    <a href="/dashboard">📊 Dashboard</a>
    <a href="/install-page">⚡ Instalare</a>
    <a href="/docs">📚 Docs</a>
    <a href="/login">🔑 Autentificare</a>
    <a href="/wizard-form" class="mobile-cta">🚀 Începe Gratuit</a>
  </div>
  <div class="nav-overlay" id="navOverlay"></div>
</nav>

<div class="wz-shell">
  <!-- HEADER -->
  <div class="wz-header">
    
    <div class="wz-header-sub">Configurare agent AI · 9 pași</div>
  </div>

  <!-- PROGRESS -->
  <div class="wz-progress">
    <div class="wz-progress-meta">
      <span class="wz-progress-label">Progres configurare</span>
      <span class="wz-step-counter" id="stepCounter">01 / 09</span>
    </div>
    <div class="wz-progress-bar"><div class="wz-progress-fill" id="progressFill" style="width:11%"></div></div>
    <div class="wz-step-dots" id="stepDots"></div>
  </div>

  <!-- ═══ STEP 1: PROFIL BUSINESS ═══ -->
  <div class="wz-step active" data-step="1">
    <div class="wz-step-tag">Pasul 1 — Profilul business-ului</div>
    <div class="wz-step-title">Ce tip de business conduci?</div>
    <div class="wz-step-sub">Selectează toate variantele care se aplică. Configurarea agentului va fi complet diferită în funcție de model.</div>
    
    <div class="wz-sdiv">Modelul de business</div>
    <div class="wz-card-grid" id="bizTypeGrid"></div>
    
    <div class="wz-sdiv">Dimensiunea echipei</div>
    <div class="wz-pill-wrap" id="bizSizePills"></div>
    
    <div class="wz-sdiv">Stadiul de maturitate</div>
    <div class="wz-pill-wrap" id="bizStagePills"></div>
  </div>

  <!-- ═══ STEP 2: IDENTITATE ═══ -->
  <div class="wz-step" data-step="2">
    <div class="wz-step-tag">Pasul 2 — Identitate & context</div>
    <div class="wz-step-title">Prezintă business-ul</div>
    <div class="wz-step-sub">Informațiile de bază din care agentul construiește înțelegerea completă a contextului tău.</div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Numele business-ului / brandului <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('biz_name','Nume business')">✨ Sugerează</button></div>
      <textarea class="wz-field" id="f_biz_name" placeholder="ex: NeoTerm.ro" rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_biz_name"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Ce face business-ul — în 2 propoziții <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('biz_desc','Descriere business')">✨ Sugerează</button></div>
      <textarea class="wz-field" id="f_biz_desc" placeholder="ex: Instalăm izolație celulozică pentru case și hale industriale..." rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_biz_desc"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Produse / servicii principale (cu prețuri) <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('biz_products','Produse și prețuri')">✨ Sugerează</button></div>
      <textarea class="wz-field" id="f_biz_products" placeholder="ex: Izolație celulozică — 80 lei/mp, Consultanță energetică — 500 lei..." rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_biz_products"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Clientul ideal <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('biz_client','Client ideal')">✨ Sugerează</button></div>
      <textarea class="wz-field" id="f_biz_client" placeholder="ex: Proprietari case noi, 35–55 ani, venit mediu-mare..." rows="2"></textarea>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Zona geografică / piața acoperită</div>
      <textarea class="wz-field" id="f_biz_zone" placeholder="ex: Dolj, Olt, Gorj" rows="2"></textarea>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Website / social media principale</div>
      <textarea class="wz-field" id="f_biz_web" placeholder="ex: site.ro · @brand" rows="2"></textarea>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Modelul de venit</div>
      <div class="wz-pill-wrap" id="revModelPills"></div>
    </div>
  </div>

  <!-- ═══ STEP 3: OBIECTIVE ═══ -->
  <div class="wz-step" data-step="3">
    <div class="wz-step-tag">Pasul 3 — Obiective & probleme</div>
    <div class="wz-step-title">Ce vrei să rezolvi cu AI?</div>
    
    <div class="wz-sdiv">Obiectivul principal (multi-select)</div>
    <div class="wz-card-grid wide" id="objectivesGrid"></div>
    
    <div class="wz-field-wrap" style="margin-top:20px">
      <div class="wz-field-label">Problema #1 acum <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('pain_main','Problema principală')">✨ Sugerează</button></div>
      <textarea class="wz-field" id="f_pain_main" placeholder="ex: Pierd 3–4 ore pe zi răspunzând la întrebări repetitive..." rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_pain_main"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Task-uri repetitive săptămânale <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('repetitive_tasks','Task-uri repetitive')">✨ Sugerează</button></div>
      <textarea class="wz-field" id="f_repetitive_tasks" placeholder="ex: Verificarea stocului, follow-up clienți, rapoarte..." rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_repetitive_tasks"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
    
    <div class="wz-sdiv">Timp pierdut pe săptămână pe task-uri automatizabile</div>
    <div class="wz-pill-wrap" id="timeWastePills"></div>
    
    <div class="wz-field-wrap" style="margin-top:20px">
      <div class="wz-field-label">Prioritate următoarele 90 de zile <button class="btn-suggest" class="wz-btn-ask" onclick="askAI('priority_90','Prioritate 90 zile')">✨ Propune</button></div>
      <textarea class="wz-field" id="f_priority_90" placeholder="ex: Automatizarea fluxului de proforme și follow-up" rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_priority_90"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
  </div>

  <!-- ═══ STEP 4: ECHIPA AGENȚI ═══ -->
  <div class="wz-step" data-step="4">
    <div class="wz-step-tag">Pasul 4 — Echipa de agenți</div>
    <div class="wz-step-title">Ce agenți activezi?</div>
    
    <div class="wz-sdiv">Agenți de execuție</div>
    <div class="wz-card-grid wide" id="agentsExecGrid"></div>
    
    <div class="wz-sdiv">Agenți specializați</div>
    <div class="wz-card-grid wide" id="agentsSpecGrid"></div>
  </div>

  <!-- ═══ STEP 5: CANALE ═══ -->
  <div class="wz-step" data-step="5">
    <div class="wz-step-tag">Pasul 5 — Canale & infrastructură</div>
    <div class="wz-step-title">Unde operezi?</div>
    
    <div class="wz-sdiv">Canale de comunicare</div>
    <div class="wz-pill-wrap" id="channelsPills"></div>
    
    <div class="wz-field-wrap" style="margin-top:20px">
      <div class="wz-field-label">CRM actual / Tool-uri de gestiune</div>
      <textarea class="wz-field" id="f_crm_tool" placeholder="ex: HubSpot, Google Sheets, Trello..." rows="2"></textarea>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Tool-uri & integrări dorite</div>
      <textarea class="wz-field" id="f_integrations_wish" placeholder="ex: Make.com, Zapier, Google Calendar..." rows="2"></textarea>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Buget lunar estimat pentru AI ($)</div>
      <div class="wz-pill-wrap" id="budgetPills"></div>
    </div>
  </div>

  <!-- ═══ STEP 6: PERSONALITATE ═══ -->
  <div class="wz-step" data-step="6">
    <div class="wz-step-tag">Pasul 6 — Personalitate & reguli</div>
    <div class="wz-step-title">Cum se comportă?</div>
    
    <div class="wz-sdiv">Nivel de autonomie</div>
    <div id="autonomyCards"></div>
    
    <div class="wz-sdiv">Identitate verbală (ton)</div>
    <div class="wz-pill-wrap" id="tonePills"></div>
    
    <div class="wz-field-wrap" style="margin-top:20px">
      <div class="wz-field-label">Avantaj competitiv real <button class="wz-btn-ask" onclick="askAI('competitive_adv','Avantaj competitiv')">✨ Găsește unghiul</button></div>
      <textarea class="wz-field" id="f_competitive_adv" placeholder="De ce ar alege cineva brandul tău?" rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_competitive_adv"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
    
    <div class="wz-field-wrap">
      <div class="wz-field-label">Linii roșii absolute (Reguli SOUL.md) <button class="wz-btn-ask" onclick="askAI('restrictions','Linii roșii')">✨ Sugestii</button></div>
      <textarea class="wz-field" id="f_restrictions" placeholder="ex: Nu vorbi despre politică, fără discount mai mare de 10%..." rows="2"></textarea>
      <div class="wz-ai-answer" id="ans_restrictions"><div class="wz-ai-label">🤖 AI Sugestie</div><div class="wz-ai-text"></div></div>
    </div>
  </div>

  <!-- ═══ STEP 7: CONTEXT TEHNIC ═══ -->
  <div class="wz-step" data-step="7">
    <div class="wz-step-tag">Pasul 7 — Context tehnic</div>
    <div class="wz-step-title">Experiența ta</div>
    
    <div class="wz-sdiv">Nivel experiență AI</div>
    <div id="aiExpCards"></div>
    
    <div class="wz-sdiv">Implicare în setup</div>
    <div id="setupInvCards"></div>
    
    <div class="wz-field-wrap" style="margin-top:20px">
      <div class="wz-field-label">Deadline lansare / Urgență</div>
      <textarea class="wz-field" id="f_deadline" placeholder="ex: În 2 săptămâni" rows="2"></textarea>
    </div>
  </div>

  <!-- ═══ STEP 8: GENERARE ═══ -->
  <div class="wz-step" data-step="8">
    <div class="wz-step-tag">Pasul 8 — Generare Fișiere</div>
    <div class="wz-step-title">Generare individuală / Progres</div>
    <div class="wz-step-sub">Sistemul a captat toate informațiile tale. Generează fiecare fișier pe rând pentru context optim.</div>
    
    <div class="wz-stats-row">
      <div class="wz-stat-box"><div class="wz-stat-n" id="globalPct">0%</div><div class="wz-stat-l">Completare</div></div>
      <div class="wz-stat-box"><div class="wz-stat-n" id="totalGen">0</div><div class="wz-stat-l">Fișiere generate</div></div>
      <div class="wz-stat-box">
        <button class="wz-btn-ask" onclick="generateAll()" id="genAllBtn" style="height:100%;width:100%;font-size:0.75rem">
          🔄 Generează Toate
        </button>
      </div>
    </div>
    
    <div class="wz-card-grid wide" id="filesGrid"></div>
    
    <div id="previewArea" style="display:none;margin-top:20px">
      <div class="wz-md-label" id="previewLabel">Preview</div>
      <div class="wz-md-preview" id="previewContent" style="max-height:300px"></div>
      <button class="wz-btn-next" onclick="nextStep()" style="width:100%;margin-top:12px">📝 Editează & Finalizează →</button>
    </div>
  </div>

  <!-- ═══ STEP 9: EXPORT ═══ -->
  <div class="wz-step" data-step="9">
    <div class="wz-step-tag">Pasul 9 — Rezultate & Export</div>
    <div class="wz-step-title">Biblioteca ta de Fișiere</div>
    <div class="wz-step-sub">Aici poți revizui, edita și descărca toate fișierele Markdown generate.</div>
    
    <div id="exportList" style="display:flex;flex-direction:column;gap:12px;margin-bottom:24px"></div>
    
    <div id="editArea" style="display:none;border-top:1px solid var(--border);padding-top:24px;margin-top:24px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <div class="wz-md-label" id="editLabel">Editare</div>
        <div style="display:flex;gap:8px">
          <button class="wz-btn-ask" onclick="saveEdit()" style="background:var(--green-bg);color:var(--green);border-color:var(--green-border)">💾 Salvează</button>
          <button class="wz-btn-ask" onclick="closeEdit()">✕ Închide</button>
        </div>
      </div>
      <textarea class="wz-code-editor" id="editContent"></textarea>
    </div>
    
    <div style="margin-top:40px;text-align:center">
      <button class="wz-btn-action" onclick="downloadAll()">📦 Descarcă toate fișierele</button>
      <p style="font-size:0.75rem;color:var(--text3);margin-top:12px">Configurație completă gata pentru deployment.</p>
    </div>
  </div>

  <!-- NAV -->
  <div class="wz-nav">
    <button class="wz-btn wz-btn-back" id="backBtn" onclick="prevStep()" style="visibility:hidden">← Înapoi</button>
    <div></div>
    <button class="wz-btn wz-btn-next" id="nextBtn" onclick="nextStep()">Continuă →</button>
  </div>
</div>

<!-- CHAT WIDGET -->
<button class="wz-chat-toggle" id="chatToggle" onclick="toggleChat()">💬</button>
<div class="wz-chat-panel" id="chatPanel">
  <div class="wz-chat-header">
    <span>🤖 Asistent AI</span>
    <button onclick="toggleChat()">✕</button>
  </div>
  <div class="wz-chat-msgs" id="chatMsgs">
    <div class="wz-chat-msg bot">Salut! Sunt asistentul AI. Te pot ajuta să completezi intake-ul sau să-ți rafinezi ideile pentru agent. Întreabă-mă orice!</div>
  </div>
  <div class="wz-chat-input">
    <input type="text" id="chatInput" placeholder="Scrie aici..." onkeydown="if(event.key==='Enter')sendChat()">
    <button onclick="sendChat()">➤</button>
  </div>
</div>

<script>
// ═══ DATA ═══
const BIZ_TYPES=[["🏪","B2C Local","Vinzi direct consumatorilor"],["🏢","B2B","Vinzi altor firme"],["🌐","E-commerce","Magazin online"],["🎓","Educație / Cursuri","Online sau offline"],["💻","SaaS / Tech","Software, aplicații"],["🔬","R&D / Inovație","Cercetare, prototipuri"],["🏗️","Construcții / Servicii","Manoperă, instalații"],["🏥","Medical / Wellness","Sănătate, beauty, spa"],["🍽️","HoReCa / Food","Restaurant, catering"],["🏠","Imobiliare","Vânzări, închirieri"],["⚖️","Consultanță / Legal","Avocatură, consulting"],["🎨","Creativ / Agenție","Marketing, design"],["🚚","Logistică / Transport","Livrări, depozitare"],["💰","Finanțe / Investiții","Trading, fonduri"],["🌿","Agri / Green / Energie","Ferme, eco, panouri"],["🎮","Entertainment / Gaming","Jocuri, streaming"],["✈️","Turism / Travel","Agenții, cazare"],["🏋️","Sport / Fitness","Săli, antrenament"],["🔧","Producție / Manufacturi","Fabrică, ateliere"],["🎵","Muzică / Artă / Media","Artiști, studiouri"],["🐾","Veterinar / Animale","Clinici, pet shop"],["🧑‍⚖️","ONG / Non-profit","Fundații, asociații"],["🏛️","Instituție / Autoritate","Public, municipal"],["➕","Altul","Specifică mai jos"]];
const BIZ_SIZE=["👤 Solo / Freelancer","👥 Micro (2–5)","🏢 Mică (6–20)","🏬 Medie (20–100)","🏭 Corporație (100+)"];
const BIZ_STAGE=["💡 Idee / pre-launch","🚀 Lansare (0–1 an)","📈 Creștere (1–3 ani)","🏆 Matur (3+ ani)","🔄 Pivot / restructurare"];
const REV_MODEL=["Vânzare directă","Abonament / SaaS","Proiecte / Contracte","Comision / Afiliere","Publicitate / Media","Freemium","Consultanță / Timp","Licensing / IP","Grant / Finanțare","Marketplace"];
const OBJECTIVES=[["🎯","Generare & calificare lead-uri"],["📈","Creșterea conversiei & vânzărilor"],["⚙️","Automatizare operațională"],["🔬","Research & Development"],["📢","Conținut & prezență online"],["🧠","Intelligence & decizie strategică"],["🤝","Relații clienți & suport"],["💰","Finanțe & raportare"],["🤖","Produs AI / Demo / Chatbot"],["📦","Supply chain & procurement"]];
const TIME_WASTE=["Sub 5h","5–15h","15–30h","30h+ (criză)"];
const AGENTS_EXEC=[["🎯","HUNTER — Leads","Caută prospecți și califică lead-uri"],["✍️","WRITER — Conținut","Generează postări și emailuri"],["📞","CLOSER — Vânzări","Follow-up și oferte personalizate"],["🛎️","SUPPORT — Clienți","Răspunde FAQ și reclamații"],["📊","ANALYST — KPI","Rapoarte și forecasting"],["🔭","SCOUT — Piață","Monitorizează competitorii"]];
const AGENTS_SPEC=[["🗓️","SCHEDULER","Programări și calendar"],["🧾","FINANCE","Facturi și plăți"],["📦","OPS","Comenzi și stocuri"],["🧪","R&D","Tehnologii și validare"],["🎓","TRAINER","Onboarding și wiki"],["🏗️","PM","Task-uri și deadline-uri"]];
const CHANNELS=["📱 WhatsApp","💬 Messenger","✉️ Email","💼 LinkedIn","📷 Instagram","📞 Voice AI"];
const BUDGET=["$0 (Free tools)","$20 - $50","$50 - $200","$200+"];
const AUTONOMY=[["✋","Aprobare pentru orice","Agentul pregătește, tu decizi și trimiți."],["⚡","Semi-autonom","Autonom intern, aprobare pt mesaje externe."],["🤖","Full autonom","Execută complet, primești raport zilnic."]];
const TONE=["🧪 Expert tehnic","😊 Prietenos","👔 Profesional","⚡ Energic / Vânzări","🧘 Calmat / Empatic"];
const AI_EXP=[["🌱","Începător","Am folosit ChatGPT casual, nu am automatizat serios."],["⚙️","Intermediar","Folosesc Make/Zapier, înțeleg API-uri de bază."],["🚀","Avansat","Lucrez cu API-uri și cod, configurez VPS."]];
const SETUP_INV=[["🙋","Independent","Vreau să înțeleg și să modific singur."],["🤝","Colaborare","Implicat în decizii, dar nu singurul responsabil."],["🎁","Done-for-you","Văd rezultatele, nu intru în detalii tehnice."]];
const FILES_META=[["SOUL","🧬"],["IDENTITY","🪪"],["RULES","⚖️"],["KNOWLEDGE","📚"],["TOOLS","🔧"],["WORKFLOWS","📈"],["MEMORY","🧠"],["VOICE","🎤"],["INTEGRATION","🔗"]];
const MULTI=new Set(["biz_type","ch","tone","obj","rev_model","time_waste","budget","biz_size","biz_stage","agents"]);

// ═══ STATE ═══
let cur=1;const TOTAL=9;
const sel={},vals={},genData={},progress={};
let editingKey=null,editingText='';
const token=localStorage.getItem('agentulmeu_token');

// ═══ RENDER ═══
function renderCards(containerId,data,group,wide){
  const c=document.getElementById(containerId);
  c.className='wz-card-grid'+(wide?' wide':'');
  c.innerHTML=data.map(([icon,name,desc])=>`
    <div class="wz-bcard" data-group="${group}" data-val="${name}" onclick="toggle('${group}','${name.replace(/'/g,"\\'")}',this)">
      <span class="wz-bicon">${icon}</span>
      <div class="wz-blabel">${name}</div>
      ${desc?`<div class="wz-bsub">${desc}</div>`:''}
    </div>
  `).join('');
}

function renderPills(containerId,data,group){
  const c=document.getElementById(containerId);
  c.innerHTML=data.map(p=>`
    <div class="wz-pill" data-group="${group}" data-val="${p}" onclick="toggle('${group}','${p.replace(/'/g,"\\'")}',this)">${p}</div>
  `).join('');
}

function renderAcards(containerId,data,group){
  const c=document.getElementById(containerId);
  c.innerHTML=data.map(([icon,name,desc])=>`
    <div class="wz-acard" data-group="${group}" data-val="${name}" onclick="toggle('${group}','${name.replace(/'/g,"\\'")}',this)">
      <div class="wz-aicon">${icon}</div>
      <div><div class="wz-aname">${name}</div><div class="wz-adesc">${desc}</div></div>
    </div>
  `).join('');
}

function renderDots(){
  const d=document.getElementById('stepDots');
  d.innerHTML=Array.from({length:TOTAL},(_,i)=>{
    const cls=i+1===cur?'active':i+1<cur?'done':'';
    return `<div class="wz-dot ${cls}" onclick="goToStep(${i+1})"></div>`;
  }).join('');
}

function renderFilesGrid(){
  const g=document.getElementById('filesGrid');
  g.innerHTML=FILES_META.map(([key,icon])=>{
    const p=progress[key];const done=!!genData[key];
    return `
      <div class="wz-bcard ${done?'sel':''}" style="text-align:center">
        <span class="wz-bicon">${icon}</span>
        <div class="wz-blabel">${key}.md</div>
        <div class="wz-bsub">${p?.status||'Negenerat'}</div>
        ${p&&p.pct>0&&p.pct<100?`<div style="margin-top:8px;height:4px;background:var(--bg4);border-radius:2px;overflow:hidden"><div style="height:100%;width:${p.pct}%;background:var(--gold-gradient);border-radius:2px"></div></div>`:''}
        <div style="margin-top:12px;display:flex;gap:4px">
          <button class="wz-btn-ask" style="flex:1" onclick="generateOne('${key}')">${done?'Regenerează':'⚡ Generează'}</button>
          ${done?`<button class="wz-btn-ask" onclick="previewFile('${key}')">👁️</button>`:''}
        </div>
      </div>
    `;
  }).join('');
}

function renderExportList(){
  const el=document.getElementById('exportList');
  const keys=Object.keys(genData);
  if(keys.length===0){
    el.innerHTML='<div style="text-align:center;padding:40px 20px;color:var(--text2)">Nu ai generat încă niciun fișier.<br><br><button class="wz-btn-back" onclick="goToStep(8)">← Mergi la Pasul 8</button></div>';
    return;
  }
  el.innerHTML=keys.map(key=>{
    const meta=FILES_META.find(f=>f[0]===key);
    return `
      <div class="wz-acard sel-accent" style="cursor:default">
        <div class="wz-aicon" style="font-size:1.5rem">${meta?.[1]||'📄'}</div>
        <div style="flex:1"><div class="wz-aname" style="font-size:0.9rem">${key}.md</div><div class="wz-adesc">Gata pentru export / editare</div></div>
        <div style="display:flex;gap:6px">
          <button class="wz-btn-ask" onclick="startEdit('${key}')">📝</button>
          <button class="wz-btn-ask" onclick="downloadOne('${key}')">⬇️</button>
        </div>
      </div>
    `;
  }).join('');
}

// ═══ INIT ═══
function init(){
  renderCards('bizTypeGrid',BIZ_TYPES,'biz_type');
  renderPills('bizSizePills',BIZ_SIZE,'biz_size');
  renderPills('bizStagePills',BIZ_STAGE,'biz_stage');
  renderPills('revModelPills',REV_MODEL,'rev_model');
  renderCards('objectivesGrid',OBJECTIVES,'obj',true);
  renderPills('timeWastePills',TIME_WASTE,'time_waste');
  renderCards('agentsExecGrid',AGENTS_EXEC,'agents',true);
  renderCards('agentsSpecGrid',AGENTS_SPEC,'agents',true);
  renderPills('channelsPills',CHANNELS,'ch');
  renderPills('budgetPills',BUDGET,'budget');
  renderAcards('autonomyCards',AUTONOMY,'autonomy');
  renderPills('tonePills',TONE,'tone');
  renderAcards('aiExpCards',AI_EXP,'ai_exp');
  renderAcards('setupInvCards',SETUP_INV,'setup_inv');
  renderFilesGrid();
  renderExportList();
  renderDots();
}

// ═══ TOGGLE SELECTION ═══
function toggle(group,item,el){
  const curSel=sel[group]||[];
  const has=curSel.includes(item);
  if(MULTI.has(group)){
    sel[group]=has?curSel.filter(i=>i!==item):[...curSel,item];
  } else {
    sel[group]=has?[]:[item];
  }
  // Update UI
  const container=el.parentElement;
  container.querySelectorAll('[data-group="'+group+'"]').forEach(c=>{
    c.classList.toggle('sel',sel[group]?.includes(c.dataset.val));
  });
}

// ═══ NAVIGATION ═══
function showStep(step){
  document.querySelectorAll('.wz-step').forEach(s=>{
    s.classList.toggle('active',parseInt(s.dataset.step)===step);
  });
  cur=step;
  document.getElementById('stepCounter').textContent=`${cur<10?'0':''}${cur} / 0${TOTAL}`;
  document.getElementById('progressFill').style.width=Math.round((cur/TOTAL)*100)+'%';
  document.getElementById('backBtn').style.visibility=cur>1?'visible':'hidden';
  document.getElementById('nextBtn').textContent=cur===8?'Vezi Rezultate →':cur===TOTAL?'📦 Descarcă Tot':'Continuă →';
  if(cur===8){renderFilesGrid();updateStats();}
  if(cur===9)renderExportList();
  renderDots();
  window.scrollTo({top:0,behavior:'smooth'});
}
function nextStep(){if(cur<TOTAL)showStep(cur+1)}
function prevStep(){if(cur>1)showStep(cur-1)}
function goToStep(s){if(s<=cur)showStep(s)}

// ═══ BUILD SUMMARY ═══
function buildSummary(){
  const fv=id=>{const el=document.getElementById('f_'+id);return el?el.value:'';};
  return `=== INTAKE AGENTULMEU ===
Business: ${fv('biz_name')}
Tip: ${(sel.biz_type||[]).join(', ')}
Echipa: ${(sel.biz_size||[]).join(', ')}
Maturitate: ${(sel.biz_stage||[]).join(', ')}
Descriere: ${fv('biz_desc')}
Produse: ${fv('biz_products')}
Client: ${fv('biz_client')}
Zona: ${fv('biz_zone')}
Web: ${fv('biz_web')}
Model Venit: ${(sel.rev_model||[]).join(', ')}
Obiective: ${(sel.obj||[]).join(', ')}
Problema: ${fv('pain_main')}
Task-uri: ${fv('repetitive_tasks')}
Timp pierdut: ${(sel.time_waste||[]).join(', ')}
Prioritate 90z: ${fv('priority_90')}
Agenti: ${(sel.agents||[]).join(', ')}
Canale: ${(sel.ch||[]).join(', ')}
CRM: ${fv('crm_tool')}
Integrari: ${fv('integrations_wish')}
Buget: ${(sel.budget||[]).join(', ')}
Autonomie: ${(sel.autonomy||[]).join(', ')}
Ton: ${(sel.tone||[]).join(', ')}
Avantaj: ${fv('competitive_adv')}
Restrictii: ${fv('restrictions')}
Exp AI: ${(sel.ai_exp||[]).join(', ')}
Setup: ${(sel.setup_inv||[]).join(', ')}
Deadline: ${fv('deadline')}`;
}

// ═══ ASK AI ═══
async function askAI(fieldId,label){
  const btn=event.target.closest('.wz-btn-ask');
  const ansEl=document.getElementById('ans_'+fieldId);
  btn.classList.add('loading');
  if(ansEl){ansEl.classList.add('show');ansEl.querySelector('.wz-ai-text').textContent='Se generează...';}
  
  try{
    const r=await fetch('/api/wizard/ask-ai',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':token?'Bearer '+token:''},
      body:JSON.stringify({question:`Sugerează un răspuns bun pentru: ${label}. Context: ${buildSummary().substring(0,500)}`,business_context:{}})
    });
    const d=await r.json();
    if(d.success&&d.answer){
      const formatted=d.answer.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>');
      if(ansEl)ansEl.querySelector('.wz-ai-text').innerHTML=formatted;
      // Auto-fill the field
      const field=document.getElementById('f_'+fieldId);
      if(field&&!field.value)field.value=d.answer.replace(/\*\*/g,'').replace(/\*/g,'');
    } else {
      if(ansEl)ansEl.querySelector('.wz-ai-text').textContent='✕ '+ (d.error||'Eroare');
    }
  }catch(e){
    if(ansEl)ansEl.querySelector('.wz-ai-text').textContent='✕ Eroare de conexiune';
  }
  btn.classList.remove('loading');
}

// ═══ GENERATE ONE ═══
async function generateOne(key){
  if(progress[key]?.status==='Generare...')return;
  progress[key]={pct:10,status:'Generare...'};
  renderFilesGrid();
  
  try{
    const r=await fetch('/api/generate-file',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':token?'Bearer '+token:''},
      body:JSON.stringify({file_type:key,intake_data:parseFormData()})
    });
    const d=await r.json();
    if(d.content){
      genData[key]=d.content;
      progress[key]={pct:100,status:'Gata ✅'};
      renderFilesGrid();
      updateStats();
      previewFile(key);
    } else {
      progress[key]={pct:0,status:'Eroare'};
      renderFilesGrid();
    }
  }catch(e){
    progress[key]={pct:0,status:'Eroare'};
    renderFilesGrid();
  }
}

// ═══ GENERATE ALL ═══
async function generateAll(){
  const btn=document.getElementById('genAllBtn');
  btn.disabled=true;btn.textContent='🔄 Se generează...';
  
  try{
    const r=await fetch('/api/generate-zip',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':token?'Bearer '+token:''},
      body:JSON.stringify({intake_data:parseFormData()})
    });
    const d=await r.json();
    if(d.job_id){
      await pollJob(d.job_id);
    }
  }catch(e){}
  btn.disabled=false;btn.textContent='🔄 Generează Toate';
}

async function pollJob(jobId){
  for(let i=0;i<120;i++){
    try{
      const r=await fetch(`/api/job/${jobId}/result`,{headers:{'Authorization':token?'Bearer '+token:''}});
      const d=await r.json();
      const done=d.done||0;const total=d.total||9;
      if(d.status==='done'){
        if(d.files){
          Object.keys(d.files).forEach(key=>{
            if(d.files[key].ok){genData[key]=d.files[key].content||'';progress[key]={pct:100,status:'Gata ✅'};}
          });
        }
        renderFilesGrid();updateStats();
        break;
      }
      // Update progress for generating files
      FILES_META.slice(0,done).forEach(([key])=>{
        progress[key]={pct:100,status:'Gata ✅'};
        genData[key]=genData[key]||'# '+key+'\n\nGenerat...';
      });
      renderFilesGrid();
    }catch(e){}
    await new Promise(r=>setTimeout(r,3000));
  }
}

function parseFormData(){
  const fv=id=>{const el=document.getElementById('f_'+id);return el?el.value:'';};
  return {
    business_name:fv('biz_name'),
    business_category:(sel.biz_type||[]).join(', '),
    description:fv('biz_desc'),
    products:fv('biz_products'),
    tone:(sel.tone||[]).join(', '),
    objectives:(sel.obj||[]).join(', '),
    channels:(sel.ch||[]).join(', '),
    team_size:(sel.biz_size||[]).join(', '),
    stage:(sel.biz_stage||[]).join(', '),
    revenue_model:(sel.rev_model||[]).join(', '),
    pain_points:fv('pain_main'),
    repetitive_tasks:fv('repetitive_tasks'),
    time_waste:(sel.time_waste||[]).join(', '),
    priority_90:fv('priority_90'),
    agents:(sel.agents||[]).join(', '),
    crm:fv('crm_tool'),
    integrations:fv('integrations_wish'),
    budget:(sel.budget||[]).join(', '),
    autonomy:(sel.autonomy||[]).join(', '),
    competitive_advantage:fv('competitive_adv'),
    restrictions:fv('restrictions'),
    ai_experience:(sel.ai_exp||[]).join(', '),
    setup_involvement:(sel.setup_inv||[]).join(', '),
    deadline:fv('deadline'),
    client_ideal:fv('biz_client'),
    zone:fv('biz_zone'),
    web:fv('biz_web')
  };
}

function updateStats(){
  const total=Object.keys(genData).length;
  document.getElementById('totalGen').textContent=total;
  document.getElementById('globalPct').textContent=Math.round((total/9)*100)+'%';
}

// ═══ PREVIEW ═══
function previewFile(key){
  document.getElementById('previewArea').style.display='block';
  document.getElementById('previewLabel').textContent=key+'.md Preview';
  document.getElementById('previewContent').textContent=genData[key]||'';
}

// ═══ EDIT ═══
function startEdit(key){
  editingKey=key;editingText=genData[key];
  document.getElementById('editArea').style.display='block';
  document.getElementById('editLabel').textContent=key+'.md';
  document.getElementById('editContent').value=editingText;
}
function saveEdit(){
  if(editingKey){genData[editingKey]=document.getElementById('editContent').value;alert('Salvat!');}
  document.getElementById('editArea').style.display='none';editingKey=null;
  renderExportList();
}
function closeEdit(){document.getElementById('editArea').style.display='none';editingKey=null;}

// ═══ DOWNLOAD ═══
function downloadOne(key){
  const content=genData[key];if(!content)return;
  const blob=new Blob([content],{type:'text/markdown'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download=key+'.md';a.click();
  URL.revokeObjectURL(url);
}
function downloadAll(){Object.keys(genData).forEach((k,i)=>setTimeout(()=>downloadOne(k),i*200));}

// ═══ CHAT ═══
function toggleChat(){document.getElementById('chatPanel').classList.toggle('open');}
async function sendChat(){
  const input=document.getElementById('chatInput');
  const text=input.value.trim();if(!text)return;
  const msgs=document.getElementById('chatMsgs');
  msgs.innerHTML+=`<div class="wz-chat-msg user">${text}</div>`;
  input.value='';
  msgs.innerHTML+=`<div class="wz-chat-msg bot" id="chatLoading">...</div>`;
  msgs.scrollTop=msgs.scrollHeight;
  
  try{
    const r=await fetch('/api/wizard/ask-ai',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':token?'Bearer '+token:''},
      body:JSON.stringify({question:text,business_context:{}})
    });
    const d=await r.json();
    const loading=document.getElementById('chatLoading');
    if(loading){
      if(d.success&&d.answer){
        loading.textContent=d.answer;loading.classList.remove('bot');loading.classList.add('bot');
      } else {
        loading.textContent='✕ Eroare la generare.';
      }
      loading.removeAttribute('id');
    }
  }catch(e){
    const loading=document.getElementById('chatLoading');
    if(loading){loading.textContent='✕ Eroare de conexiune.';loading.removeAttribute('id');}
  }
  msgs.scrollTop=msgs.scrollHeight;
}

// ═══ START ═══
init();
</script>

<script>
// 🔧 Handler Pasul 8: Generare Fișiere
function wizardStep8Handler() {
  const btn = document.querySelector('button:contains("Generează Toate")') || 
              document.querySelector('.wz-btn-action') || 
              Array.from(document.querySelectorAll('button')).find(b => b.textContent.includes('Generează Toate'));
  if (!btn) return;

  btn.onclick = async function() {
    this.disabled = true; this.textContent = '⏳ Se generează...';
    try {
      // Colectează toate datele din wizard
      const ctx = {};
      document.querySelectorAll('input, textarea, select').forEach(el => {
        const key = el.name || el.id || el.placeholder;
        if (key && el.value) ctx[key] = el.value;
      });

      const res = await fetch('/api/wizard/generate', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ context: ctx })
      });
      const data = await res.json();

      if (data.success && data.files) {
        // Update UI: marchează fișierele ca generate
        const files = Object.keys(data.files);
        files.forEach(f => {
          const card = document.querySelector(`[data-file="${f}"]`) || 
                       Array.from(document.querySelectorAll('.file-card, .wz-card, div')).find(c => c.textContent.includes(f));
          if (card) {
            const status = card.querySelector('.status, .file-status, span');
            if (status) status.textContent = 'Generat ✅';
          }
        });
        // Update progres
        const bar = document.querySelector('.progress-bar, .wz-progress-bar');
        const txt = document.querySelector('.progress-text, .wz-progress-meta span');
        if (bar) bar.style.width = '100%';
        if (txt) txt.textContent = '100%';
        
        localStorage.setItem('wizardGeneratedFiles', JSON.stringify(data.files));
        alert('✅ Toate cele 9 fișiere au fost generate cu succes!');
      } else {
        alert('❌ Eroare la generare: ' + (data.error || 'Răspuns invalid'));
      }
    } catch (e) {
      alert('❌ Eroare rețea: ' + e.message);
    } finally {
      this.disabled = false; this.textContent = '🔄 Generează Toate';
    }
  };
}
document.addEventListener('DOMContentLoaded', wizardStep8Handler);
</script>

<script src="/assets/js/global-nav.js" defer></script>
</body>
</html>
