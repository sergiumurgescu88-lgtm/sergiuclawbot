<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Autentificare — AgentulMeu</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#fff;color:#111;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.card{background:#fff;border:1px solid rgba(0,0,0,0.08);border-radius:24px;padding:48px 40px;width:100%;max-width:420px;box-shadow:0 12px 40px rgba(0,0,0,0.06);animation:fadeInUp .5s ease-out}
.card:hover{box-shadow:0 20px 60px rgba(0,0,0,0.08)}
.logo{text-align:center;margin-bottom:32px}
.logo-icon{width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,#C9A227,#E8C547,#C9A227);display:inline-flex;align-items:center;justify-content:center;font-weight:800;font-size:1.2rem;color:#fff;margin-bottom:12px;box-shadow:0 8px 24px rgba(201,162,39,0.3);animation:float 4s ease-in-out infinite}
h1{font-size:1.4rem;font-weight:800;text-align:center;margin-bottom:4px;letter-spacing:-0.02em}
.subtitle{text-align:center;color:#888;font-size:0.88rem;margin-bottom:32px}
label{display:block;font-size:0.82rem;font-weight:600;margin-bottom:6px;color:#555}
input{width:100%;padding:12px 16px;border-radius:12px;border:1px solid rgba(0,0,0,0.1);background:#f8f9fa;font-size:0.92rem;font-family:Inter,sans-serif;transition:all .2s;color:#111}
input:focus{outline:none;border-color:#C9A227;box-shadow:0 0 0 3px rgba(201,162,39,0.12);background:#fff}
.btn{width:100%;padding:14px;border-radius:12px;border:none;font-size:0.95rem;font-weight:700;cursor:pointer;transition:all .3s ease;font-family:Inter,sans-serif}
.btn-primary{background:linear-gradient(135deg,#C9A227,#E8C547,#C9A227);color:#0a0a0a;box-shadow:0 8px 24px rgba(201,162,39,0.25);font-weight:700}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(201,162,39,0.35)}
.link{text-align:center;margin-top:20px;font-size:0.85rem;color:#888}
.link a{color:#C9A227;text-decoration:none;font-weight:600}
.link a:hover{text-decoration:underline}
.error{background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);color:#dc2626;padding:10px 14px;border-radius:10px;font-size:0.82rem;margin-bottom:16px;display:none}
</style>
  
  <link rel="icon" type="image/png" href="/assets/uploads/logoagentulmeu/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/uploads/logoagentulmeu/favicon.ico">
<link rel="stylesheet" href="/assets/css/premium-design.css">
<link rel="stylesheet" href="/assets/css/global-nav.css">
</head>
<body>
<nav class="global-nav" id="globalNav">
  <div class="nav-container">
    <a href="/" class="nav-logo">Agentul<span class="logo-accent">Meu</span></a>
    <div class="nav-links desktop-only">
      <a href="/wizard-form">Wizard</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/install-page">Instalare</a>
      <a href="/docs">Docs</a>
      <a href="/login">Autentificare</a>
      <a href="/wizard-form" class="nav-cta">Începe Gratuit</a>
    </div>
    <button class="hamburger mobile-only" id="navToggle" aria-label="Meniu">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/wizard-form">🪄 Wizard</a>
    <a href="/dashboard">📊 Dashboard</a>
    <a href="/install-page">⚡ Instalare</a>
    <a href="/docs">📚 Docs</a>
    <a href="/login">🔑 Autentificare</a>
    <a href="/wizard-form" class="mobile-cta">🚀 Începe Gratuit</a>
  </div>
  <div class="nav-overlay" id="navOverlay"></div>
</nav>
<div class="card">
  <div class="logo"></div>
  <h1>Bine ai revenit</h1>
  <p class="subtitle">Intră în contul tău AgentulMeu</p>
  <div class="error" id="error"></div>
  <form id="loginForm" style="display:grid;gap:16px">
    <div><label for="username">Username</label><input type="text" id="username" required placeholder="username"></div>
    <div><label for="password">Parolă</label><input type="password" id="password" required placeholder="••••••••"></div>
    <button type="submit" class="btn btn-primary">Autentificare</button>
  </form>
  <p class="link">Nu ai cont? <a href="/register">Creează unul gratuit</a></p>
</div>
<script>
document.getElementById('loginForm').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = e.target.querySelector('button');
  btn.textContent = 'Se autentifică...'; btn.disabled = true;
  try {
    const r = await fetch('/api/auth/login', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        username: document.getElementById('username').value,
        password: document.getElementById('password').value
      })
    });
    const d = await r.json();
    if (d.token) {
      localStorage.setItem('agentulmeu_token', d.token);
      window.location.href = '/dashboard';
    } else {
      const err = document.getElementById('error');
      err.textContent = d.error || 'Autentificare eșuată';
      err.style.display = 'block';
    }
  } catch(e) {
    document.getElementById('error').textContent = 'Eroare de conexiune';
    document.getElementById('error').style.display = 'block';
  }
  btn.textContent = 'Autentificare'; btn.disabled = false;
});
</script>
<script src="/assets/js/global-nav.js" defer></script>
</body>
</html>
